@using YTMusic.Services
@inject MusicPlayerService PlayerService
@inject IJSRuntime JSRuntime
@implements IDisposable

<!-- Persistent media elements across navigation -->
<audio @ref="_audioElement" autoplay style="display:none;" />
<div @ref="_videoHost" class="ytm-global-video-host" aria-hidden="true">
    <video @ref="_videoElement" playsinline preload="metadata" class="ytm-global-video" />
</div>

@code {
    private ElementReference _audioElement;
    private ElementReference _videoElement;
    private ElementReference _videoHost;
    private DotNetObjectReference<GlobalAudioPlayer>? _objRef;
    private string? _lastUrl = null;
    private bool _lastIsVideo;

    protected override void OnInitialized()
    {
        PlayerService.OnChange += OnPlayerStateChanged;
        PlayerService.OnRequestReplay += OnRequestReplay;
        PlayerService.OnRequestPause += OnRequestPause;
        PlayerService.OnRequestPlay += OnRequestPlay;
        PlayerService.OnRequestSeek += OnRequestSeek;
        PlayerService.OnTimeChanged += OnPlayerTimeChanged;
    }

    private void OnPlayerTimeChanged()
    {
        if (!PlayerService.IsUsingNativePlayback && !PlayerService.IsUsingNativeVideoPlayback)
        {
            return;
        }

        _ = InvokeAsync(async () =>
        {
            try
            {
                await JSRuntime.InvokeVoidAsync(
                    "audioPlayer.setProgress",
                    PlayerService.CurrentTime,
                    PlayerService.Duration);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[AudioProgressSyncError] {ex.Message}");
            }
        });
    }

    private void OnRequestReplay()
    {
        _ = InvokeAsync(async () =>
        {
            try
            {
                if (!PlayerService.IsUsingNativePlayback
                    && !PlayerService.IsUsingNativeVideoPlayback
                    && PlayerService.CurrentStreamUrl != null
                    && PlayerService.CurrentVideo?.LocalFilePath != null)
                {
                    await JSRuntime.InvokeVoidAsync(
                        "audioPlayer.replayFromStart",
                        PlayerService.CurrentStreamUrl,
                        PlayerService.IsCurrentStreamWebM,
                        PlayerService.IsCurrentStreamVideo);
                }
                else
                {
                    await JSRuntime.InvokeVoidAsync("audioPlayer.setCurrentTime", 0);
                    await JSRuntime.InvokeVoidAsync("audioPlayer.play");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[AudioReplayError] {ex.Message}");
            }
        });
    }

    private void OnPlayerStateChanged()
    {
        if (PlayerService.IsUsingNativePlayback)
        {
            return;
        }

        _ = InvokeAsync(async () =>
        {
            try
            {
                if (PlayerService.CurrentStreamUrl != null &&
                    (PlayerService.CurrentStreamUrl != _lastUrl || PlayerService.IsCurrentStreamVideo != _lastIsVideo))
                {
                    _lastUrl = PlayerService.CurrentStreamUrl;
                    _lastIsVideo = PlayerService.IsCurrentStreamVideo;
                    await SyncWebStreamAsync();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[AudioStateSyncError] {ex.Message}");
            }
        });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _objRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("audioPlayer.init", _audioElement, _videoElement, _videoHost, _objRef);

            if (!PlayerService.IsUsingNativePlayback && PlayerService.CurrentStreamUrl != null)
            {
                _lastUrl = PlayerService.CurrentStreamUrl;
                _lastIsVideo = PlayerService.IsCurrentStreamVideo;
                await SyncWebStreamAsync();
            }
        }
    }

    private async Task SyncWebStreamAsync()
    {
        if (PlayerService.IsUsingNativePlayback || PlayerService.CurrentStreamUrl == null)
        {
            return;
        }

        await JSRuntime.InvokeVoidAsync(
            "audioPlayer.loadSource",
            PlayerService.CurrentStreamUrl,
            PlayerService.IsCurrentStreamWebM,
            PlayerService.IsCurrentStreamVideo);

        if (PlayerService.IsPlaying)
        {
            await JSRuntime.InvokeVoidAsync("audioPlayer.play");
        }
    }

    private void OnRequestPause()
    {
        _ = InvokeAsync(async () =>
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("audioPlayer.pause");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[AudioPauseError] {ex.Message}");
            }
        });
    }

    private void OnRequestPlay()
    {
        _ = InvokeAsync(async () =>
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("audioPlayer.play");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[AudioPlayError] {ex.Message}");
            }
        });
    }

    private void OnRequestSeek(double positionSeconds)
    {
        _ = InvokeAsync(async () =>
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("audioPlayer.setCurrentTime", positionSeconds);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[AudioSeekError] {ex.Message}");
            }
        });
    }

    [JSInvokable]
    public void OnTimeUpdate(double currentTime)
    {
        PlayerService.UpdateTime(currentTime);
    }

    [JSInvokable]
    public async Task OnProgressSeek(double positionSeconds)
    {
        await PlayerService.SeekAsync(positionSeconds);
    }

    [JSInvokable]
    public void OnLoadedMetadata(double duration)
    {
        PlayerService.UpdateDuration(duration);
    }

    [JSInvokable]
    public async Task OnEnded()
    {
        await PlayerService.OnTrackEndedAsync();
    }

    [JSInvokable]
    public void OnPlayStateChanged(bool isPlaying)
    {
        PlayerService.SetPlayingState(isPlaying);
    }

    [JSInvokable]
    public void OnPlaybackError(string details)
    {
        Console.WriteLine($"[AudioPlaybackError] {details}");
    }

    public void Dispose()
    {
        PlayerService.OnChange -= OnPlayerStateChanged;
        PlayerService.OnRequestReplay -= OnRequestReplay;
        PlayerService.OnRequestPause -= OnRequestPause;
        PlayerService.OnRequestPlay -= OnRequestPlay;
        PlayerService.OnRequestSeek -= OnRequestSeek;
        PlayerService.OnTimeChanged -= OnPlayerTimeChanged;
        if (_objRef != null)
        {
            _objRef.Dispose();
            try
            {
                _ = JSRuntime.InvokeVoidAsync("audioPlayer.dispose");
            }
            catch { }
        }
    }
}
