@inherits LayoutComponentBase
@using MudBlazor
@using YTMusic.BLL.Abstractions
@using YTMusic.Services
@using YTMusic.ViewModels
@inject GlobalStateService GlobalState
@inject IJSRuntime JSRuntime
@inject WindowChromeService WindowChrome
@inject UiPreferencesService UiPreferences
@inject MainLayoutVM LayoutVM
@implements IDisposable

<MudThemeProvider Theme="@LayoutVM.CurrentMudTheme" IsDarkMode="@LayoutVM.CurrentIsDark" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<div style="@LayoutVM.CurrentThemeCssVars">
    <MudLayout Class="ytm-shell">
        <MudAppBar Elevation="0" Fixed="true" Color="Color.Transparent" Class="ytm-topbar">
            <div class="ytm-topbar-inner">
                <button class="ytm-brand" @onclick='() => NavigateToTab("")'>
                    <MudIcon Icon="@Icons.Material.Filled.PlayCircleFilled" />
                    <span>YTMusic</span>
                </button>

                @if (IsWindowsDesktop)
                {
                    <div class="ytm-window-drag"
                         @onmousedown="BeginWindowDrag"
                         @ondblclick="ToggleWindowMaximize"
                         title="Drag window">
                    </div>

                    <MudIconButton Icon="@Icons.Material.Filled.Menu"
                                   Color="Color.Default"
                                   Class="ytm-theme-toggle ytm-theme-toggle-desktop"
                                   OnClick="LayoutVM.ToggleThemePanel"
                                   aria-label="Open Theme Panel" />

                    <div class="ytm-window-controls">
                        <MudIconButton Icon="@Icons.Material.Rounded.Minimize"
                                       Color="Color.Default"
                                       Class="ytm-window-button"
                                       OnClick="MinimizeWindow"
                                       aria-label="Minimize Window" />
                        <MudIconButton Icon="@Icons.Material.Outlined.CropSquare"
                                       Color="Color.Default"
                                       Class="ytm-window-button"
                                       OnClick="ToggleWindowMaximize"
                                       aria-label="Toggle Maximize Window" />
                        <MudIconButton Icon="@Icons.Material.Rounded.Close"
                                       Color="Color.Default"
                                       Class="ytm-window-button ytm-window-button-close"
                                       OnClick="CloseWindow"
                                       aria-label="Close Window" />
                    </div>
                }
                else
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Menu"
                                   Color="Color.Default"
                                   Class="ytm-theme-toggle ytm-theme-toggle-mobile"
                                   OnClick="LayoutVM.ToggleThemePanel"
                                   aria-label="Open Theme Panel" />
                }
            </div>
        </MudAppBar>

        <MudMainContent Class="ytm-main">
            <MudOverlay Visible="GlobalState.IsLoading"
                        DarkBackground="true"
                        Absolute="true"
                        LockScroll="false"
                        ZIndex="100"
                        Class="ytm-content-loading-overlay">
                <div class="d-flex flex-column align-center justify-center">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                    <MudText Typo="Typo.h6" Color="Color.Primary" Class="mt-4">Loading...</MudText>
                </div>
            </MudOverlay>
            <div class="ytm-content">
                <div class="ytm-body">
                    @Body
                </div>
            </div>
            <GlobalAudioPlayer />
        </MudMainContent>
    </MudLayout>

    <div class="ytm-theme-backdrop @( LayoutVM.IsThemePanelOpen ? "is-open" : "" )" @onclick="LayoutVM.CloseThemePanel"></div>

    <aside class="ytm-theme-panel @( LayoutVM.IsThemePanelOpen ? "is-open" : "" )" aria-hidden="@(!LayoutVM.IsThemePanelOpen)">
        <div class="ytm-theme-panel-header">
            <MudText Typo="Typo.h6">Theme</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="LayoutVM.CloseThemePanel" aria-label="Close Theme Panel" />
        </div>
        <div class="ytm-theme-list">
            @for (var i = 0; i < ThemePresets.All.Length; i++)
            {
                var index = i;
                var item = ThemePresets.All[index];
                <button class="@LayoutVM.GetThemeItemClass(index)" @onclick="@(() => LayoutVM.SelectTheme(index))">
                    <span class="ytm-theme-dot" style="background:@item.PreviewColor;"></span>
                    <span>@item.Name</span>
                </button>
            }
            <div class="ytm-setting-item">
                <div class="ytm-setting-copy">
                    <span class="ytm-theme-dot" style="background: var(--ytm-accent);"></span>
                    <div class="ytm-setting-text">
                        <span>Favorites Image</span>
                        <small>Show thumbnails on favorite cards</small>
                    </div>
                </div>
                <MudSwitch T="bool"
                           Color="Color.Primary"
                           Value="UiPreferences.ShowFavoriteCardImages"
                           ValueChanged="LayoutVM.OnShowFavoriteCardImagesChanged" />
            </div>
            <div class="ytm-setting-item">
                <div class="ytm-setting-copy">
                    <span class="ytm-theme-dot" style="background: var(--ytm-accent);"></span>
                    <div class="ytm-setting-text">
                        <span>两行显示</span>
                        <small>开启后标题最多两行，超出显示省略号；关闭则完整显示</small>
                    </div>
                </div>
                <MudSwitch T="bool"
                           Color="Color.Primary"
                           Value="UiPreferences.MediaTitleTwoLines"
                           ValueChanged="LayoutVM.OnMediaTitleTwoLinesChanged" />
            </div>
            <div class="ytm-setting-item">
                <div class="ytm-setting-copy">
                    <span class="ytm-theme-dot" style="background: var(--ytm-accent);"></span>
                    <div class="ytm-setting-text">
                        <span>视频流后台预检</span>
                        <small>播放在线音频时后台解析视频流，点视频时更快（额外消耗流量）</small>
                    </div>
                </div>
                <MudSwitch T="bool"
                           Color="Color.Primary"
                           Value="UiPreferences.PrefetchRemoteVideo"
                           ValueChanged="LayoutVM.OnPrefetchRemoteVideoChanged" />
            </div>
            <div class="ytm-setting-item">
                <div class="ytm-setting-copy">
                    <span class="ytm-theme-dot" style="background: var(--ytm-accent);"></span>
                    <div class="ytm-setting-text">
                        <span>分离流视频画质</span>
                        <small>无 muxed 时 video-only 分辨率：最低起播更快，最高画质更好</small>
                    </div>
                </div>
                <MudSelect T="RemoteVideoStreamQuality"
                           Dense="true"
                           Margin="Margin.Dense"
                           Value="UiPreferences.RemoteVideoStreamQuality"
                           ValueChanged="LayoutVM.OnRemoteVideoStreamQualityChanged"
                           Style="max-width: 6.5rem;">
                    <MudSelectItem Value="RemoteVideoStreamQuality.Lowest">最低</MudSelectItem>
                    <MudSelectItem Value="RemoteVideoStreamQuality.Highest">最高</MudSelectItem>
                </MudSelect>
            </div>
            <button class="ytm-theme-item" @onclick="CopyDownloadPathAsync">
                <span class="ytm-theme-dot" style="background: var(--ytm-accent);"></span>
                <span>Copy Download Path</span>
            </button>
            <button class="ytm-theme-item ytm-theme-item-danger" @onclick="LayoutVM.ResetToDefaultsAsync">
                <span class="ytm-theme-dot" style="background: #EF4444;"></span>
                <span>还原默认</span>
            </button>
        </div>
    </aside>

    <MudPaper Elevation="0" id="ytm-bottom-nav" Class="ytm-bottom-nav"
              Style="position: fixed; left: 0; right: 0; bottom: 0; z-index: 5000; display: flex; justify-content: space-around; border-radius: 0; padding-bottom: env(safe-area-inset-bottom);">
 
        <div @onclick='() => NavigateToTab("favorites")' class="@GetBottomItemClass("Favorites")">
            <MudIcon Icon="@Icons.Material.Filled.Favorite" Style="@GetBottomItemContentStyle("Favorites")" />
            <MudText Typo="Typo.caption" Style="@GetBottomItemContentStyle("Favorites")">Favorites</MudText>
        </div>
        <div @onclick='() => NavigateToTab("player")' class="@GetBottomItemClass("Player")">
            <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Style="@GetBottomItemContentStyle("Player")" />
            <MudText Typo="Typo.caption" Style="@GetBottomItemContentStyle("Player")">Player</MudText>
        </div>
        <div @onclick='() => NavigateToTab("")' class="@GetBottomItemClass("Search")">
            <MudIcon Icon="@Icons.Material.Filled.Search" Style="@GetBottomItemContentStyle("Search")" />
            <MudText Typo="Typo.caption" Style="@GetBottomItemContentStyle("Search")">Home</MudText>
        </div>
        <div @onclick='() => NavigateToTab("other")' class="@GetBottomItemClass("Other")">
            <MudIcon Icon="@Icons.Material.Filled.MoreHoriz" Style="@GetBottomItemContentStyle("Other")" />
            <MudText Typo="Typo.caption" Style="@GetBottomItemContentStyle("Other")">Other</MudText>
        </div>
    </MudPaper>
</div>

@code {
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
    private EventHandler<LocationChangedEventArgs>? _locationChangedHandler;
    private bool _shouldRestorePageScroll;
    private bool _isWindowDragging;
    private bool _isPendingMaximizedDrag;
    private double _dragStartScreenX;
    private double _dragStartScreenY;
    private DotNetObjectReference<MainLayout>? _windowDragRef;
    private const double MaximizedDragThreshold = 8;

    public string SelectedNavValue { get; set; } = "Search";

    protected override void OnInitialized()
    {
        LayoutVM.StateHasChanged = StateHasChanged;
        LayoutVM.Initialize();
        GlobalState.OnChange += StateHasChanged;
        UiPreferences.OnChange += StateHasChanged;
        UpdateSelectedNavValue();
        _locationChangedHandler = OnLocationChanged;
        NavigationManager.LocationChanged += _locationChangedHandler;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (IsWindowsDesktop)
            {
                _windowDragRef = DotNetObjectReference.Create(this);
            }

            await JSRuntime.InvokeVoidAsync("ytmLayout.initBottomNav", "ytm-bottom-nav");
            await JSRuntime.InvokeVoidAsync("ytmLayout.initPageScrollPersistence");
            return;
        }

        if (_shouldRestorePageScroll)
        {
            _shouldRestorePageScroll = false;
            try
            {
                await JSRuntime.InvokeVoidAsync("ytmLayout.restorePageScrolls");
            }
            catch
            {
                // WebView may not be ready during shutdown.
            }
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateSelectedNavValue();
        _shouldRestorePageScroll = true;
        _ = InvokeAsync(StateHasChanged);
    }

    private void UpdateSelectedNavValue()
    {
        var uri = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).ToLower();
        if (uri.Contains("favorites")) SelectedNavValue = "Favorites";
        else if (uri.Contains("player")) SelectedNavValue = "Player";
        else if (uri.Contains("other") || uri.Contains("downloads") || uri.Contains("transfers") || uri.Contains("upload") || uri.Contains("history")) SelectedNavValue = "Other";
        else SelectedNavValue = "Search";
    }

    private void NavigateToTab(string route)
    {
        _ = NavigateToTabAsync(route);
    }

    private async Task NavigateToTabAsync(string route)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("ytmLayout.saveAllPageScrolls");
        }
        catch
        {
            // WebView may not be ready during shutdown.
        }

        NavigationManager.NavigateTo(route);
    }

    private async Task CopyDownloadPathAsync()
        => await LayoutVM.CopyDownloadPathAsync(JSRuntime);

    private async Task BeginWindowDrag(MouseEventArgs args)
    {
        if (!IsWindowsDesktop || args.Button != 0)
        {
            return;
        }

        if (WindowChrome.IsWindowMaximized())
        {
            _isPendingMaximizedDrag = true;
            _isWindowDragging = false;
            _dragStartScreenX = args.ScreenX;
            _dragStartScreenY = args.ScreenY;
        }
        else
        {
            _isPendingMaximizedDrag = false;
            _isWindowDragging = true;
            WindowChrome.StartWindowMove();
        }

        await JSRuntime.InvokeVoidAsync("mouseDragInterop.startDrag", _windowDragRef);
    }

    private void MinimizeWindow()
    {
        if (!IsWindowsDesktop)
        {
            return;
        }

        WindowChrome.MinimizeWindow();
    }

    private void ToggleWindowMaximize()
    {
        if (!IsWindowsDesktop)
        {
            return;
        }

        WindowChrome.ToggleMaximizeWindow();
    }

    private void CloseWindow()
    {
        if (!IsWindowsDesktop)
        {
            return;
        }

        WindowChrome.CloseWindow();
    }

    [JSInvokable]
    public async Task OnGlobalMouseMove(double screenX, double screenY)
    {
        if (!IsWindowsDesktop)
        {
            return;
        }

        if (_isPendingMaximizedDrag)
        {
            var deltaX = screenX - _dragStartScreenX;
            var deltaY = screenY - _dragStartScreenY;
            var movedEnough = Math.Max(Math.Abs(deltaX), Math.Abs(deltaY)) >= MaximizedDragThreshold;
            if (!movedEnough)
            {
                return;
            }

            WindowChrome.RestoreWindowForDrag(screenX, screenY);
            await Task.Delay(16);
            WindowChrome.StartWindowMove();
            _isPendingMaximizedDrag = false;
            _isWindowDragging = true;
        }

        if (!_isWindowDragging)
        {
            return;
        }

        WindowChrome.MoveWindow();
    }

    [JSInvokable]
    public void OnGlobalMouseUp(double screenX, double screenY)
    {
        if (!IsWindowsDesktop)
        {
            return;
        }

        if (_isPendingMaximizedDrag)
        {
            _isPendingMaximizedDrag = false;
            return;
        }

        if (!_isWindowDragging)
        {
            return;
        }

        _isWindowDragging = false;
        WindowChrome.EndWindowMove();
    }

    private string GetBottomItemClass(string tab)
    {
        return SelectedNavValue == tab ? "ytm-bottom-item is-active" : "ytm-bottom-item";
    }

    private string GetBottomItemContentStyle(string tab)
    {
        return SelectedNavValue == tab
            ? "color: var(--ytm-nav-active-text);"
            : "color: var(--ytm-nav-text);";
    }

    public void Dispose()
    {
        LayoutVM.Dispose();
        GlobalState.OnChange -= StateHasChanged;
        UiPreferences.OnChange -= StateHasChanged;
        if (_locationChangedHandler != null)
        {
            NavigationManager.LocationChanged -= _locationChangedHandler;
            _locationChangedHandler = null;
        }

        _windowDragRef?.Dispose();
        _windowDragRef = null;
    }

    private static bool IsWindowsDesktop => OperatingSystem.IsWindows();
}
