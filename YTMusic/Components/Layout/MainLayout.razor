@inherits LayoutComponentBase
@using MudBlazor
@using YTMusic.Services
@inject GlobalStateService GlobalState
@inject IJSRuntime JSRuntime
@implements IDisposable

<MudThemeProvider Theme="@CurrentMudTheme" IsDarkMode="@CurrentIsDark" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout Class="ytm-shell" Style="@CurrentThemeCssVars">
    <MudOverlay Visible="GlobalState.IsLoading" DarkBackground="true" Absolute="false" ZIndex="9999">
        <div class="d-flex flex-column align-center justify-center">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Typo="Typo.h6" Color="Color.Primary" Class="mt-4">Loading...</MudText>
        </div>
    </MudOverlay>

    <MudAppBar Elevation="0" Fixed="true" Color="Color.Transparent" Class="ytm-topbar">
        <div class="ytm-topbar-inner">
            <button class="ytm-brand" @onclick='() => NavigateToTab("")'>
                <MudIcon Icon="@Icons.Material.Filled.PlayCircleFilled" />
                <span>YTMusic</span>
            </button>

            <button class="ytm-search-pill" @onclick='() => NavigateToTab("")'>
                <MudIcon Icon="@Icons.Material.Filled.Search" />
                <span>Search songs, albums, artists</span>
            </button>

            <MudIconButton Icon="@Icons.Material.Filled.Menu"
                           Color="Color.Default"
                           Class="ytm-theme-toggle"
                           OnClick="ToggleThemePanel"
                           aria-label="Open Theme Panel" />
        </div>
    </MudAppBar>

    <MudMainContent Class="ytm-main" Style="padding-bottom: 98px;">
        <MudContainer MaxWidth="MaxWidth.False" Class="ytm-content">
            @Body
        </MudContainer>
        <GlobalAudioPlayer />
    </MudMainContent>
</MudLayout>

<div class="ytm-theme-backdrop @( _isThemePanelOpen ? "is-open" : "" )" @onclick="CloseThemePanel"></div>

<aside class="ytm-theme-panel @( _isThemePanelOpen ? "is-open" : "" )" aria-hidden="@(!_isThemePanelOpen)">
    <div class="ytm-theme-panel-header">
        <MudText Typo="Typo.h6">Theme</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="CloseThemePanel" aria-label="Close Theme Panel" />
    </div>
    <div class="ytm-theme-list">
        @for (var i = 0; i < _themes.Length; i++)
        {
            var index = i;
            var item = _themes[index];
            <button class="@GetThemeItemClass(index)" @onclick="@(() => SelectTheme(index))">
                <span class="ytm-theme-dot" style="background:@item.PreviewColor;"></span>
                <span>@item.Name</span>
            </button>
        }
    </div>
</aside>

<MudPaper Elevation="0" id="ytm-bottom-nav" Class="ytm-bottom-nav"
          Style="position: fixed; left: 0; right: 0; bottom: 0; z-index: 5000; display: flex; justify-content: space-around; border-radius: 0; padding-bottom: env(safe-area-inset-bottom);">
    <div @onclick='() => NavigateToTab("")' class="@GetBottomItemClass("Search")">
        <MudIcon Icon="@Icons.Material.Filled.Search" />
        <MudText Typo="Typo.caption">Home</MudText>
    </div>
    <div @onclick='() => NavigateToTab("favorites")' class="@GetBottomItemClass("Favorites")">
        <MudIcon Icon="@Icons.Material.Filled.Favorite" />
        <MudText Typo="Typo.caption">Favorites</MudText>
    </div>
    <div @onclick='() => NavigateToTab("player")' class="@GetBottomItemClass("Player")">
        <MudIcon Icon="@Icons.Material.Filled.PlayCircle" />
        <MudText Typo="Typo.caption">Player</MudText>
    </div>
    <div @onclick='() => NavigateToTab("downloads")' class="@GetBottomItemClass("Downloads")">
        <MudIcon Icon="@Icons.Material.Filled.LibraryMusic" />
        <MudText Typo="Typo.caption">Library</MudText>
    </div>
    <div @onclick='() => NavigateToTab("transfers")' class="@GetBottomItemClass("Transfers")">
        <MudIcon Icon="@Icons.Material.Filled.CloudDownload" />
        <MudText Typo="Typo.caption">Transfers</MudText>
    </div>
</MudPaper>

@code {
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
    private EventHandler<LocationChangedEventArgs>? _locationChangedHandler;
    private bool _isThemePanelOpen;
    private int _themeIndex;

    public string SelectedNavValue { get; set; } = "Search";

    protected override void OnInitialized()
    {
        GlobalState.OnChange += StateHasChanged;
        UpdateSelectedNavValue();
        _locationChangedHandler = OnLocationChanged;
        NavigationManager.LocationChanged += _locationChangedHandler;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await JSRuntime.InvokeVoidAsync("ytmLayout.initBottomNav", "ytm-bottom-nav");
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateSelectedNavValue();
        _ = InvokeAsync(StateHasChanged);
    }

    private void UpdateSelectedNavValue()
    {
        var uri = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).ToLower();
        if (uri.Contains("favorites")) SelectedNavValue = "Favorites";
        else if (uri.Contains("player")) SelectedNavValue = "Player";
        else if (uri.Contains("downloads")) SelectedNavValue = "Downloads";
        else if (uri.Contains("transfers")) SelectedNavValue = "Transfers";
        else SelectedNavValue = "Search";
    }

    private void NavigateToTab(string route)
    {
        NavigationManager.NavigateTo(route);
    }

    private void ToggleThemePanel()
    {
        _isThemePanelOpen = !_isThemePanelOpen;
    }

    private void CloseThemePanel()
    {
        _isThemePanelOpen = false;
    }

    private void SelectTheme(int index)
    {
        if (_themes.Length == 0)
        {
            return;
        }

        _themeIndex = Math.Clamp(index, 0, _themes.Length - 1);
        _isThemePanelOpen = false;
    }

    private string GetBottomItemClass(string tab)
    {
        return SelectedNavValue == tab ? "ytm-bottom-item is-active" : "ytm-bottom-item";
    }

    private string GetThemeItemClass(int index)
    {
        return index == _themeIndex ? "ytm-theme-item is-active" : "ytm-theme-item";
    }

    public void Dispose()
    {
        GlobalState.OnChange -= StateHasChanged;
        if (_locationChangedHandler != null)
        {
            NavigationManager.LocationChanged -= _locationChangedHandler;
            _locationChangedHandler = null;
        }
    }

    private ThemePreset ActiveTheme
    {
        get
        {
            if (_themes.Length == 0)
            {
                return _fallbackTheme;
            }

            var safeIndex = Math.Clamp(_themeIndex, 0, _themes.Length - 1);
            if (safeIndex != _themeIndex)
            {
                _themeIndex = safeIndex;
            }

            return _themes[safeIndex];
        }
    }

