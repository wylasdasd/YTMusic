@page "/player/video"
@using YTMusic.Services
@using MudBlazor
@using YTMusic.Components.Dialogs
@inject MusicPlayerService PlayerService
@inject IDialogService DialogService
@inject IFavoriteService FavoriteService
@inject IDownloadManagerService DownloadManager
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageListScroll PageKey="player-video" Class="player-page-scroll">
    <ChildContent>
<MudContainer MaxWidth="MaxWidth.False" Class="player-screen player-screen--video">
    @{
        var currentVideo = PlayerService.CurrentVideo;
    }
    @if (currentVideo == null)
    {
        <div class="player-empty">
            <MudIcon Icon="@Icons.Material.Filled.VideoLibrary" Style="font-size: 4rem;" Color="Color.Secondary" Class="mb-4" />
            <MudText Typo="Typo.h5" Color="Color.Secondary">No video is currently playing</MudText>
        </div>
    }
    else
    {
        <div class="player-shell">
            <div class="player-backdrop"
                 style="@($"background-image: linear-gradient(180deg, color-mix(in srgb, var(--ytm-bg-base) 18%, transparent), color-mix(in srgb, var(--ytm-bg-base) 92%, transparent)), url('{currentVideo.ThumbnailUrl}');")">
            </div>

            <div class="player-content player-content--video">
                @if (!PlayerService.UseNativeVideoPlayback)
                {
                    <div class="player-video-frame" @ref="_videoFrame"></div>
                }

                <div class="player-meta player-meta--video">
                    <MediaTitle Text="@currentVideo.Title"
                                Typo="Typo.h5"
                                Class="player-title" />
                    <MudText Typo="Typo.body1" Class="player-author">
                        @currentVideo.Author
                    </MudText>
                    <MudText Typo="Typo.caption" Class="player-video-note">
                        @(PlayerService.UseNativeVideoPlayback ? "Android 原生 ExoPlayer 播放中" : "视频播放使用下方视频组件自带控件")
                    </MudText>
                </div>

                <div class="player-actions-row">
                    <div class="player-actions-left">
                        <MudIconButton Icon="@Icons.Material.Filled.MusicNote"
                                       Color="Color.Secondary"
                                       OnClick="PlayAudioAsync"
                                       Disabled="@PlayerService.IsSwitchingTrack"
                                       aria-label="Switch to audio" />
                        <MudIconButton
                            Icon="@(IsFavorite ? Icons.Material.Filled.Favorite : Icons.Material.Outlined.FavoriteBorder)"
                            Color="@(IsFavorite ? Color.Error : Color.Default)"
                            OnClick="OpenFavoriteDialogAsync"
                            aria-label="Toggle Favorite" />
                        <MudMenu Icon="@Icons.Material.Filled.Download"
                                 Color="Color.Primary"
                                 AnchorOrigin="Origin.BottomRight"
                                 TransformOrigin="Origin.TopRight"
                                 aria-label="Download">
                            <MudMenuItem OnClick="@(() => Download(false))">Download Audio</MudMenuItem>
                            <MudMenuItem OnClick="@(() => Download(true))">Download Video</MudMenuItem>
                        </MudMenu>
                    </div>
                </div>
            </div>
        </div>
    }
</MudContainer>
    </ChildContent>
</PageListScroll>

@code {
    private bool IsFavorite = false;
    private string? _currentCheckedVideoId;
    private string? _currentCheckedVideoSourceId;
    private ElementReference _videoFrame;
    private bool _videoAttached;
    private bool CanPlayVideo;

    protected override void OnInitialized()
    {
        if (OperatingSystem.IsAndroid() && PlayerService.UseNativeVideoPlayback)
        {
            NavigationManager.NavigateTo("/player/audio", replace: true);
            return;
        }

        PlayerService.OnChange += OnStateChanged;
        _ = CheckFavoriteStatusAsync();
        _ = CheckVideoAvailabilityAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (OperatingSystem.IsAndroid() && PlayerService.UseNativeVideoPlayback)
        {
            return;
        }

        if (PlayerService.UseNativeVideoPlayback)
        {
            return;
        }

        if (PlayerService.CurrentVideo != null && !_videoAttached)
        {
            await JSRuntime.InvokeVoidAsync("audioPlayer.attachVideoTo", _videoFrame);
            _videoAttached = true;
        }
    }

    private void OnStateChanged()
    {
        if (OperatingSystem.IsAndroid() && PlayerService.UseNativeVideoPlayback)
        {
            NavigationManager.NavigateTo("/player/audio", replace: true);
            return;
        }

        if (!PlayerService.IsCurrentStreamVideo)
        {
            if (!PlayerService.UseNativeVideoPlayback)
            {
                _ = JSRuntime.InvokeVoidAsync("audioPlayer.clearVideoElement");
            }
            _videoAttached = false;
            NavigationManager.NavigateTo("/player/audio", replace: true);
            return;
        }

        _ = CheckFavoriteStatusAsync();
        _ = CheckVideoAvailabilityAsync();
        _ = AttachVideoIfNeededAsync();
        InvokeAsync(StateHasChanged);
    }

    private async Task AttachVideoIfNeededAsync()
    {
        if (PlayerService.UseNativeVideoPlayback || _videoAttached || PlayerService.CurrentVideo == null)
        {
            return;
        }

        try
        {
            await JSRuntime.InvokeVoidAsync("audioPlayer.attachVideoTo", _videoFrame);
            _videoAttached = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PlayerVideo] attach video failed: {ex.Message}");
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (OperatingSystem.IsAndroid() && PlayerService.UseNativeVideoPlayback)
        {
            NavigationManager.NavigateTo("/player/audio", replace: true);
            return;
        }

        if (!PlayerService.IsCurrentStreamVideo)
        {
            NavigationManager.NavigateTo("/player/audio", replace: true);
        }
    }

    private async Task CheckFavoriteStatusAsync()
    {
        var currentVideo = PlayerService.CurrentVideo;
        if (currentVideo == null)
        {
            IsFavorite = false;
            _currentCheckedVideoId = null;
            return;
        }

        var trackingId = !string.IsNullOrEmpty(currentVideo.LocalFilePath) ? currentVideo.LocalFilePath : currentVideo.VideoId;
        if (_currentCheckedVideoId == trackingId)
        {
            return;
        }

        _currentCheckedVideoId = trackingId;

        if (!string.IsNullOrEmpty(currentVideo.LocalFilePath))
        {
            var track = await FavoriteService.GetTrackByFilePathAsync(currentVideo.LocalFilePath);
            IsFavorite = track != null;
        }
        else
        {
            var folders = await FavoriteService.GetFavoriteFolderIdsForVideoAsync(currentVideo.VideoId);
            IsFavorite = folders.Any();
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task CheckVideoAvailabilityAsync()
    {
        var currentVideo = PlayerService.CurrentVideo;
        if (currentVideo == null)
        {
            CanPlayVideo = false;
            _currentCheckedVideoSourceId = null;
            return;
        }

        var sourceId = !string.IsNullOrWhiteSpace(currentVideo.LocalFilePath)
            ? currentVideo.LocalFilePath
            : currentVideo.VideoId;

        if (_currentCheckedVideoSourceId == sourceId)
        {
            return;
        }

        _currentCheckedVideoSourceId = sourceId;
        CanPlayVideo = await PlayerService.CanPlayCurrentAsVideoAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OpenFavoriteDialogAsync()
    {
        var currentVideo = PlayerService.CurrentVideo;
        if (currentVideo == null) return;

        string videoId = currentVideo.VideoId;

        if (!string.IsNullOrEmpty(currentVideo.LocalFilePath))
        {
            var existingTrack = await FavoriteService.GetTrackByFilePathAsync(currentVideo.LocalFilePath);
            videoId = existingTrack?.VideoId ?? Guid.NewGuid().ToString("N").Substring(0, 11);
        }

        var parameters = new DialogParameters
        {
            { "VideoId", videoId },
            { "Title", currentVideo.Title },
            { "Author", currentVideo.Author },
            { "ThumbnailUrl", currentVideo.ThumbnailUrl },
            { "LocalFilePath", currentVideo.LocalFilePath }
        };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<FavoriteFolderDialog>("Add to Favorite Folder", parameters, options);
        await dialog.Result;

        _currentCheckedVideoId = null;
        await CheckFavoriteStatusAsync();
    }

    private async Task PlayAudioAsync()
    {
        if (PlayerService.IsSwitchingTrack)
        {
            return;
        }

        if (await PlayerService.PlayCurrentAsAudioAsync())
        {
            if (!PlayerService.UseNativeVideoPlayback)
            {
                await JSRuntime.InvokeVoidAsync("audioPlayer.clearVideoElement");
            }

            await JSRuntime.InvokeVoidAsync("audioPlayer.detachVideo");
            _videoAttached = false;
            NavigationManager.NavigateTo("/player/audio", replace: true);
        }
    }

    private void Download(bool isVideo)
    {
        var currentVideo = PlayerService.CurrentVideo;
        if (currentVideo == null) return;

        if (currentVideo.VideoId == "local")
        {
            Snackbar.Add("This file is already downloaded.", Severity.Warning);
            return;
        }

        DownloadManager.StartDownload(currentVideo.VideoId, currentVideo.Title, isVideo);
        Snackbar.Add($"Started downloading: {currentVideo.Title}", Severity.Success);
    }

    public void Dispose()
    {
        PlayerService.OnChange -= OnStateChanged;
        if (!PlayerService.UseNativeVideoPlayback && PlayerService.IsCurrentStreamVideo)
        {
            _ = JSRuntime.InvokeVoidAsync("audioPlayer.detachVideo");
        }
        _videoAttached = false;
    }
}
