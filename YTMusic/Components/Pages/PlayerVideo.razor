@page "/player/video"
@using YTMusic.BLL.Ports
@using YTMusic.Services
@using MudBlazor
@inject MusicPlayerService PlayerService
@inject PlayerVM ViewModel
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageListScroll PageKey="player-video" Class="player-page-scroll">
    <ChildContent>
<MudContainer MaxWidth="MaxWidth.False" Class="player-screen player-screen--video">
    @{
        var currentVideo = PlayerService.CurrentVideo;
    }
    @if (currentVideo == null)
    {
        <div class="player-empty">
            <MudIcon Icon="@Icons.Material.Filled.VideoLibrary" Style="font-size: 4rem;" Color="Color.Secondary" Class="mb-4" />
            <MudText Typo="Typo.h5" Color="Color.Secondary">No video is currently playing</MudText>
        </div>
    }
    else
    {
        <div class="player-shell">
            <div class="player-backdrop"
                 style="@($"background-image: linear-gradient(180deg, color-mix(in srgb, var(--ytm-bg-base) 18%, transparent), color-mix(in srgb, var(--ytm-bg-base) 92%, transparent)), url('{currentVideo.ThumbnailUrl}');")">
            </div>

            <div class="player-content player-content--video">
                @if (!PlayerService.UseNativeVideoPlayback)
                {
                    <div class="player-video-frame">
                        <div class="player-video-frame__mount" @ref="_videoFrame"></div>
                        @if (_videoAttached)
                        {
                            <button type="button"
                                    class="player-video-fullscreen-btn"
                                    @onclick="ToggleFullscreenAsync"
                                    aria-label="@(_isFullscreen ? "Exit fullscreen" : "Enter fullscreen")">
                                <MudIcon Icon="@(_isFullscreen ? Icons.Material.Filled.FullscreenExit : Icons.Material.Filled.Fullscreen)" />
                            </button>
                        }
                    </div>
                }

                <div class="player-meta player-meta--video">
                    <MediaTitle Text="@currentVideo.Title"
                                Typo="Typo.h5"
                                Class="player-title" />
                    <MudText Typo="Typo.body1" Class="player-author">
                        @currentVideo.Author
                    </MudText>
                    @if (PlayerService.UseNativeVideoPlayback)
                    {
                        <MudText Typo="Typo.caption" Class="player-video-note">
                            Android 原生 ExoPlayer 播放中
                        </MudText>
                    }
                </div>

                @if (!PlayerService.UseNativeVideoPlayback)
                {
                    <div class="player-progress player-progress--video" @ref="_progressHost"></div>
                }

                <div class="player-actions-row">
                    <div class="player-actions-left">
                        <MudIconButton Icon="@Icons.Material.Filled.MusicNote"
                                       Color="Color.Secondary"
                                       OnClick="PlayAudioAsync"
                                       Disabled="@PlayerService.IsSwitchingTrack"
                                       aria-label="Switch to audio" />
                        <MudIconButton
                            Icon="@(ViewModel.IsFavorite ? Icons.Material.Filled.Favorite : Icons.Material.Outlined.FavoriteBorder)"
                            Color="@(ViewModel.IsFavorite ? Color.Error : Color.Default)"
                            OnClick="OpenFavoriteDialogAsync"
                            aria-label="Toggle Favorite" />
                        <MudMenu Icon="@Icons.Material.Filled.Download"
                                 Color="Color.Primary"
                                 AnchorOrigin="Origin.BottomRight"
                                 TransformOrigin="Origin.TopRight"
                                 aria-label="Download">
                            <MudMenuItem OnClick="@(() => Download(false))">Download Audio</MudMenuItem>
                            <MudMenuItem OnClick="@(() => Download(true))">Download Video</MudMenuItem>
                        </MudMenu>
                    </div>

                    <MudIconButton Icon="@PlayerVM.GetPlaybackModeIcon(PlayerService.CurrentMode)"
                                   Color="Color.Default"
                                   Size="Size.Medium"
                                   OnClick="TogglePlaybackMode"
                                   aria-label="Toggle Playback Mode"
                                   Disabled="@(PlayerService.Playlist.Count == 0)" />
                </div>

                @if (!PlayerService.UseNativeVideoPlayback)
                {
                    <div class="player-controls">
                        <MudIconButton Icon="@Icons.Material.Filled.SkipPrevious"
                                       Size="Size.Large"
                                       Variant="Variant.Text"
                                       OnClick="PlayPreviousTrack"
                                       Disabled="@(PlayerService.Playlist.Count == 0 || PlayerService.IsSwitchingTrack)" />

                        @if (PlayerService.IsLoading)
                        {
                            <MudProgressCircular Size="Size.Large" Indeterminate="true" Class="mx-2" />
                        }
                        else
                        {
                            <MudIconButton Icon="@(PlayerService.IsPlaying ? Icons.Material.Filled.PauseCircle : Icons.Material.Filled.PlayCircle)"
                                           Size="Size.Large"
                                           Color="Color.Primary"
                                           OnClick="TogglePlay"
                                           Disabled="@PlayerService.IsSwitchingTrack"
                                           Class="player-main-button" />
                        }

                        <MudIconButton Icon="@Icons.Material.Filled.SkipNext"
                                       Size="Size.Large"
                                       Variant="Variant.Text"
                                       OnClick="PlayNextTrack"
                                       Disabled="@(PlayerService.Playlist.Count == 0 || PlayerService.IsSwitchingTrack)" />
                    </div>
                }
            </div>
        </div>
    }
</MudContainer>
    </ChildContent>
</PageListScroll>

@code {
    private string? _currentCheckedVideoSourceId;
    private ElementReference _videoFrame;
    private bool _videoAttached;
    private bool CanPlayVideo;
    private ElementReference _progressHost;
    private bool _progressMounted;
    private string? _progressTrackKey;
    private bool _lastNativeProgressMode;
    private bool _isFullscreen;
    private DotNetObjectReference<PlayerVideo>? _fullscreenObjRef;

    protected override void OnInitialized()
    {
        if (OperatingSystem.IsAndroid() && PlayerService.UseNativeVideoPlayback)
        {
            NavigationManager.NavigateTo("/player/audio", replace: true);
            return;
        }

        ViewModel.StateHasChanged = StateHasChanged;
        PlayerService.OnChange += OnStateChanged;
        _ = ViewModel.RefreshFavoriteStatusAsync(PlayerService.CurrentVideo);
        _ = CheckVideoAvailabilityAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (OperatingSystem.IsAndroid() && PlayerService.UseNativeVideoPlayback)
        {
            return;
        }

        if (PlayerService.UseNativeVideoPlayback)
        {
            return;
        }

        if (PlayerService.CurrentVideo != null && !_videoAttached)
        {
            await AttachVideoFrameAsync();
            await SyncWebVideoFromServiceAsync();
        }

        if (PlayerService.CurrentVideo != null && !PlayerService.UseNativeVideoPlayback)
        {
            await MountProgressBarAsync();
        }
    }

    private void OnStateChanged()
    {
        if (OperatingSystem.IsAndroid() && PlayerService.UseNativeVideoPlayback)
        {
            NavigationManager.NavigateTo("/player/audio", replace: true);
            return;
        }

        if (!PlayerService.IsCurrentStreamVideo)
        {
            if (!PlayerService.UseNativeVideoPlayback)
            {
                _ = JSRuntime.InvokeVoidAsync("audioPlayer.clearVideoElement");
            }
            _videoAttached = false;
            NavigationManager.NavigateTo("/player/audio", replace: true);
            return;
        }

        _ = ViewModel.RefreshFavoriteStatusAsync(PlayerService.CurrentVideo);
        _ = CheckVideoAvailabilityAsync();
        _ = AttachVideoIfNeededAsync();
        _ = SyncWebVideoFromServiceAsync();
        _ = SyncPlayerChromeAsync();
        InvokeAsync(StateHasChanged);
    }

    private string? GetProgressTrackKey()
    {
        var current = PlayerService.CurrentVideo;
        if (current == null)
        {
            return null;
        }

        return !string.IsNullOrEmpty(current.LocalFilePath) ? current.LocalFilePath : current.VideoId;
    }

    private async Task SyncPlayerChromeAsync()
    {
        if (PlayerService.UseNativeVideoPlayback || PlayerService.CurrentVideo == null)
        {
            return;
        }

        var trackKey = GetProgressTrackKey();
        var native = PlayerService.IsUsingNativePlayback || PlayerService.IsUsingNativeVideoPlayback;
        if (!_progressMounted || trackKey != _progressTrackKey)
        {
            _progressTrackKey = trackKey;
            await MountProgressBarAsync();
        }
        else if (native != _lastNativeProgressMode)
        {
            await SyncProgressModeAsync();
        }
        else if (PlayerService.IsSwitchingTrack)
        {
            await JSRuntime.InvokeVoidAsync(
                "audioPlayer.setProgress",
                PlayerService.CurrentTime,
                PlayerService.Duration,
                true);
        }

        _lastNativeProgressMode = native;
    }

    private async Task MountProgressBarAsync()
    {
        if (PlayerService.UseNativeVideoPlayback || PlayerService.CurrentVideo == null)
        {
            return;
        }

        try
        {
            await JSRuntime.InvokeVoidAsync("audioPlayer.mountProgressBar", _progressHost);
            await SyncProgressModeAsync();
            await JSRuntime.InvokeVoidAsync(
                "audioPlayer.setProgress",
                PlayerService.CurrentTime,
                PlayerService.Duration,
                true);
            _progressMounted = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PlayerVideo] mount progress failed: {ex.Message}");
        }
    }

    private async Task SyncProgressModeAsync()
    {
        var native = PlayerService.IsUsingNativePlayback || PlayerService.IsUsingNativeVideoPlayback;
        await JSRuntime.InvokeVoidAsync("audioPlayer.setNativeProgressMode", native);
    }

    private async Task AttachVideoIfNeededAsync()
    {
        if (PlayerService.UseNativeVideoPlayback || _videoAttached || PlayerService.CurrentVideo == null)
        {
            return;
        }

        try
        {
            PlaybackDiagnostics.Log(
                $"PlayerVideo.AttachVideo hybrid={PlayerService.IsUsingHybridWebVideo} url={PlaybackDiagnostics.DescribeUrl(PlayerService.CurrentStreamUrl)}");
            await AttachVideoFrameAsync();
            await SyncWebVideoFromServiceAsync();
        }
        catch (Exception ex)
        {
            PlaybackDiagnostics.LogError("PlayerVideo attach video failed", ex);
        }
    }

    private async Task SyncWebVideoFromServiceAsync()
    {
        if (PlayerService.UseNativeVideoPlayback
            || !PlayerService.IsCurrentStreamVideo
            || PlayerService.CurrentStreamUrl == null)
        {
            return;
        }

        await JSRuntime.InvokeVoidAsync(
            "audioPlayer.syncWebVideoState",
            PlayerService.CurrentStreamUrl,
            PlayerService.IsCurrentStreamWebM,
            PlayerService.IsUsingHybridWebVideo,
            PlayerService.IsPlaying,
            PlayerService.CurrentTime);
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (OperatingSystem.IsAndroid() && PlayerService.UseNativeVideoPlayback)
        {
            NavigationManager.NavigateTo("/player/audio", replace: true);
            return;
        }

        if (!PlayerService.IsCurrentStreamVideo)
        {
            NavigationManager.NavigateTo("/player/audio", replace: true);
        }
    }

    private async Task CheckVideoAvailabilityAsync()
    {
        var currentVideo = PlayerService.CurrentVideo;
        if (currentVideo == null)
        {
            CanPlayVideo = false;
            _currentCheckedVideoSourceId = null;
            return;
        }

        var sourceId = !string.IsNullOrWhiteSpace(currentVideo.LocalFilePath)
            ? currentVideo.LocalFilePath
            : currentVideo.VideoId;

        if (_currentCheckedVideoSourceId == sourceId)
        {
            return;
        }

        _currentCheckedVideoSourceId = sourceId;
        CanPlayVideo = await PlayerService.CanPlayCurrentAsVideoAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task TogglePlay()
    {
        if (PlayerService.IsPlaying)
        {
            await PlayerService.PauseAsync();
        }
        else
        {
            await PlayerService.ResumeAsync();
        }
    }

    private async Task OpenFavoriteDialogAsync()
    {
        var currentVideo = PlayerService.CurrentVideo;
        if (currentVideo == null)
        {
            return;
        }

        await ViewModel.OpenFavoriteDialogAsync(currentVideo);
    }

    private async Task PlayNextTrack()
    {
        await PlayerService.PlayNextAsync();
    }

    private async Task PlayPreviousTrack()
    {
        await PlayerService.PlayPreviousAsync();
    }

    private void TogglePlaybackMode()
    {
        PlayerService.TogglePlaybackMode();
        StateHasChanged();
    }

    private async Task AttachVideoFrameAsync()
    {
        _fullscreenObjRef ??= DotNetObjectReference.Create(this);
        await JSRuntime.InvokeVoidAsync("audioPlayer.registerFullscreenListener", _fullscreenObjRef);
        await JSRuntime.InvokeVoidAsync("audioPlayer.attachVideoTo", _videoFrame);
        _videoAttached = true;
        _isFullscreen = await JSRuntime.InvokeAsync<bool>("audioPlayer.isVideoFullscreen");
        await InvokeAsync(StateHasChanged);
    }

    private async Task ToggleFullscreenAsync()
    {
        await JSRuntime.InvokeVoidAsync("audioPlayer.toggleVideoFullscreen");
        _isFullscreen = await JSRuntime.InvokeAsync<bool>("audioPlayer.isVideoFullscreen");
        StateHasChanged();
    }

    [JSInvokable]
    public void OnVideoFullscreenChanged(bool isFullscreen)
    {
        _isFullscreen = isFullscreen;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task PlayAudioAsync()
    {
        if (PlayerService.IsSwitchingTrack)
        {
            return;
        }

        if (await PlayerService.PlayCurrentAsAudioAsync())
        {
            if (!PlayerService.UseNativeVideoPlayback)
            {
                await JSRuntime.InvokeVoidAsync("audioPlayer.clearVideoElement");
            }

            await JSRuntime.InvokeVoidAsync("audioPlayer.detachVideo");
            _videoAttached = false;
            NavigationManager.NavigateTo("/player/audio", replace: true);
        }
    }

    private void Download(bool isVideo)
    {
        var currentVideo = PlayerService.CurrentVideo;
        if (currentVideo == null)
        {
            return;
        }

        ViewModel.Download(currentVideo, isVideo);
    }

    public void Dispose()
    {
        PlayerService.OnChange -= OnStateChanged;
        if (_progressMounted)
        {
            _ = JSRuntime.InvokeVoidAsync("audioPlayer.unmountProgressBar");
        }
        _ = JSRuntime.InvokeVoidAsync("audioPlayer.exitVideoFullscreen");
        _ = JSRuntime.InvokeVoidAsync("audioPlayer.unregisterFullscreenListener");
        if (!PlayerService.UseNativeVideoPlayback && PlayerService.IsCurrentStreamVideo)
        {
            _ = JSRuntime.InvokeVoidAsync("audioPlayer.detachVideo");
        }
        _videoAttached = false;
        _fullscreenObjRef?.Dispose();
        _fullscreenObjRef = null;
    }
}
