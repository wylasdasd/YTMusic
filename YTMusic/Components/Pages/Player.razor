@page "/player"
@inject NavigationManager NavigationManager
@inject YTMusic.Services.MusicPlayerService PlayerService

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var target = PlayerService.IsCurrentStreamVideo && !(OperatingSystem.IsAndroid() && PlayerService.UseNativeVideoPlayback)
            ? "/player/video"
            : "/player/audio";

        NavigationManager.NavigateTo(target, replace: true);
    }
}
