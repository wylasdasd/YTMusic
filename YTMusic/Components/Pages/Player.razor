@page "/player"
@using YTMusic.Services
@using MudBlazor
@using YTMusic.Components.Dialogs
@using Microsoft.Maui.ApplicationModel
@inject MusicPlayerService PlayerService
@inject IDialogService DialogService
@inject IFavoriteService FavoriteService
@inject IDownloadManagerService DownloadManager
@inject ISnackbar Snackbar
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    @if (_showNotificationPermissionHint)
    {
        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
            Android 通知权限未开启，锁屏/通知栏可能无法显示播放进度条。
            <div class="mt-2 d-flex" style="gap: 8px;">
                <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" OnClick="RequestNotificationPermissionAsync">
                    授权通知
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small" OnClick="OpenAppNotificationSettingsAsync">
                    打开系统设置
                </MudButton>
            </div>
        </MudAlert>
    }
    else if (OperatingSystem.IsAndroid())
    {
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            锁屏没有媒体卡片？请检查：锁屏通知已允许、系统“显示媒体控制”已开启、应用电池策略为“不限制”。
            <div class="mt-2 d-flex" style="gap: 8px;">
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" OnClick="OpenAppNotificationSettingsAsync">
                    打开系统设置
                </MudButton>
            </div>
        </MudAlert>
    }

    @if (PlayerService.CurrentVideo?.VideoId != "local")
    {
        <div class="d-flex justify-end mb-2">
            <MudSwitch @bind-Value="PlayerService.UseWebM" Label="High Quality (WebM/Opus)" Color="Color.Primary" />
        </div>
    }

    @if (PlayerService.CurrentVideo != null)
    {
        <MudCard Elevation="4" Class="pa-6">
            <MudCardMedia Image="@PlayerService.CurrentVideo.ThumbnailUrl" Height="300"
                          Style="border-radius: 8px; background-size: cover; background-position: center;" />

            <MudCardContent Class="text-center mt-4">
                @if (!string.IsNullOrEmpty(PlayerService.CurrentPlaylistName))
                {
                    <MudText Typo="Typo.caption" Color="Color.Primary" Style="font-weight: bold; text-transform: uppercase;">
                        正在播放: @PlayerService.CurrentPlaylistName
                    </MudText>
                }
                <MudText Typo="Typo.h5"
                         Style="font-weight: bold; margin-bottom: 8px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                    @PlayerService.CurrentVideo.Title
                </MudText>
                <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
                    @PlayerService.CurrentVideo.Author
                </MudText>
            </MudCardContent>

            <div class="px-4 mt-2">
                <MudSlider T="double" Value="@PlayerService.CurrentTime" Max="@PlayerService.Duration"
                           ValueChanged="OnSliderValueChanged" Immediate="false" Color="Color.Primary" />
                <div class="d-flex justify-space-between mt-1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatTime(PlayerService.CurrentTime)</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatTime(PlayerService.Duration)</MudText>
                </div>
            </div>

            <MudCardActions Class="mt-2" Style="width: 100%; display: flex; flex-direction: column; gap: 4px;">
                <div class="d-flex align-center justify-space-between" style="width: 100%;">
                    <div class="d-flex align-center">
                        <MudIconButton
                        Icon="@(IsFavorite ? Icons.Material.Filled.Favorite : Icons.Material.Outlined.FavoriteBorder)"
                        Color="@(IsFavorite ? Color.Error : Color.Default)" OnClick="OpenFavoriteDialogAsync"
                        aria-label="Toggle Favorite" />
                        <MudMenu Icon="@Icons.Material.Filled.Download" Color="Color.Primary" AnchorOrigin="Origin.BottomRight"
                                 TransformOrigin="Origin.TopRight" aria-label="Download">
                            <MudMenuItem OnClick="@(() => Download(false))">Download Audio</MudMenuItem>
                            <MudMenuItem OnClick="@(() => Download(true))">Download Video</MudMenuItem>
                        </MudMenu>
                    </div>

                    <MudIconButton Icon="@GetPlaybackModeIcon(PlayerService.CurrentMode)" Color="Color.Default"
                                   OnClick="TogglePlaybackMode" aria-label="Toggle Playback Mode"
                                   Disabled="@(PlayerService.Playlist.Count == 0)" />
                </div>

                <div class="d-flex align-center justify-center" style="width: 100%; gap: 14px;">
                    <MudIconButton Icon="@Icons.Material.Filled.SkipPrevious" Size="Size.Large" Variant="Variant.Text"
                                   OnClick="PlayPreviousTrack" Disabled="@(PlayerService.Playlist.Count == 0)" />

                    @if (PlayerService.IsLoading)
                    {
                        <MudProgressCircular Size="Size.Large" Indeterminate="true" Class="mx-2" />
                    }
                    else
                    {
                        <MudIconButton
                        Icon="@(PlayerService.IsPlaying ? Icons.Material.Filled.PauseCircle : Icons.Material.Filled.PlayCircle)"
                        Size="Size.Large" Color="Color.Primary" OnClick="TogglePlay"
                        Style="width: 64px; height: 64px; font-size: 3rem;" />
                    }

                    <MudIconButton Icon="@Icons.Material.Filled.SkipNext" Size="Size.Large" Variant="Variant.Text"
                                   OnClick="PlayNextTrack" Disabled="@(PlayerService.Playlist.Count == 0)" />
                </div>
            </MudCardActions>
        </MudCard>
    }
    else
    {
        <div class="d-flex flex-column align-center justify-center" style="height: 50vh;">
            <MudIcon Icon="@Icons.Material.Filled.MusicOff" Style="font-size: 4rem;" Color="Color.Secondary" Class="mb-4" />
            <MudText Typo="Typo.h5" Color="Color.Secondary">No track is currently playing</MudText>
        </div>
    }
</MudContainer>

@code {
    private bool IsFavorite = false;
    private string? _currentCheckedVideoId;
    private bool _showNotificationPermissionHint;

    protected override void OnInitialized()
    {
        PlayerService.OnChange += OnStateChanged;
        PlayerService.OnTimeChanged += OnTimeChanged;
        _ = CheckFavoriteStatusAsync();
        _ = RefreshNotificationPermissionHintAsync(requestPermission: false);
    }

    private void OnStateChanged()
    {
        _ = CheckFavoriteStatusAsync();
        InvokeAsync(StateHasChanged);
    }

    private DateTime _lastSliderInteraction = DateTime.MinValue;
    private double _lastReportedTime = 0;

    private void OnTimeChanged()
    {
        // Skip updates if user just interacted with the slider (avoid jump-back)
        if (DateTime.UtcNow - _lastSliderInteraction < TimeSpan.FromSeconds(1.5))
            return;

        // Throttling: only update UI if time changed significantly (e.g. 250ms+)
        if (Math.Abs(PlayerService.CurrentTime - _lastReportedTime) < 0.25)
            return;

        _lastReportedTime = PlayerService.CurrentTime;
        InvokeAsync(StateHasChanged);
    }

    private async Task CheckFavoriteStatusAsync()
    {
        var currentVideo = PlayerService.CurrentVideo;
        if (currentVideo == null)
        {
            IsFavorite = false;
            _currentCheckedVideoId = null;
            return;
        }

        var trackingId = !string.IsNullOrEmpty(currentVideo.LocalFilePath) ? currentVideo.LocalFilePath : currentVideo.VideoId;
        if (_currentCheckedVideoId == trackingId)
        {
            return; // unchanged, do not query DB again
        }

        _currentCheckedVideoId = trackingId;

        if (!string.IsNullOrEmpty(currentVideo.LocalFilePath))
        {
            var track = await FavoriteService.GetTrackByFilePathAsync(currentVideo.LocalFilePath);
            IsFavorite = track != null;
        }
        else
        {
            var folders = await FavoriteService.GetFavoriteFolderIdsForVideoAsync(currentVideo.VideoId);
            IsFavorite = folders.Any();
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task OpenFavoriteDialogAsync()
    {
        var currentVideo = PlayerService.CurrentVideo;
        if (currentVideo == null) return;

        string videoId = currentVideo.VideoId;

        if (!string.IsNullOrEmpty(currentVideo.LocalFilePath))
        {
            var existingTrack = await FavoriteService.GetTrackByFilePathAsync(currentVideo.LocalFilePath);
            videoId = existingTrack?.VideoId ?? Guid.NewGuid().ToString("N").Substring(0, 11);
        }

        var parameters = new DialogParameters
        {
            { "VideoId", videoId },
            { "Title", currentVideo.Title },
            { "Author", currentVideo.Author },
            { "ThumbnailUrl", currentVideo.ThumbnailUrl },
            { "LocalFilePath", currentVideo.LocalFilePath }
        };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<YTMusic.Components.Dialogs.FavoriteFolderDialog>("Add to Favorite Folder",
parameters, options);
        await dialog.Result;

        // Force a re-check
        _currentCheckedVideoId = null;
        await CheckFavoriteStatusAsync();
    }

    private async Task TogglePlay()
    {
        await RefreshNotificationPermissionHintAsync(requestPermission: false);

        if (PlayerService.IsPlaying)
            await PlayerService.PauseAsync();
        else
            await PlayerService.ResumeAsync();
    }

    private async Task PlayNextTrack()
    {
        await PlayerService.PlayNextAsync();
    }

    private async Task PlayPreviousTrack()
    {
        await PlayerService.PlayPreviousAsync();
    }

    private void TogglePlaybackMode()
    {
        PlayerService.TogglePlaybackMode();
        StateHasChanged(); // Ensure UI updates
    }

    private string GetPlaybackModeIcon(MusicPlayerService.PlaybackMode mode)
    {
        return mode switch
        {
            MusicPlayerService.PlaybackMode.Sequential => Icons.Material.Filled.Repeat,
            MusicPlayerService.PlaybackMode.Random => Icons.Material.Filled.Shuffle,
            MusicPlayerService.PlaybackMode.SingleLoop => Icons.Material.Filled.RepeatOne,
            _ => Icons.Material.Filled.Repeat
        };
    }

    private async Task OnSliderValueChanged(double value)
    {
        _lastSliderInteraction = DateTime.UtcNow;
        _lastReportedTime = value;
        await PlayerService.SeekAsync(value);
        StateHasChanged(); // Force update to reflect manual seek immediately
    }

    private string FormatTime(double seconds)
    {
        if (double.IsNaN(seconds) || double.IsInfinity(seconds)) return "00:00";
        var ts = TimeSpan.FromSeconds(seconds);
        return ts.ToString(@"mm\:ss");
    }

    private void Download(bool isVideo)
    {
        var currentVideo = PlayerService.CurrentVideo;
        if (currentVideo == null) return;

        // Exclude local files from downloading since they already exist
        if (currentVideo.VideoId == "local")
        {
            Snackbar.Add("This file is already downloaded.", Severity.Warning);
            return;
        }

        DownloadManager.StartDownload(currentVideo.VideoId, currentVideo.Title, isVideo);
        Snackbar.Add($"Started downloading: {currentVideo.Title}", Severity.Success);
    }

    private async Task RequestNotificationPermissionAsync()
    {
        await RefreshNotificationPermissionHintAsync(requestPermission: true);
        if (!_showNotificationPermissionHint)
        {
            Snackbar.Add("通知权限已开启。", Severity.Success);
        }
    }

    private Task OpenAppNotificationSettingsAsync()
    {
        try
        {
            AppInfo.Current.ShowSettingsUI();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"无法打开系统设置: {ex.Message}", Severity.Error);
        }

        return Task.CompletedTask;
    }

    private async Task RefreshNotificationPermissionHintAsync(bool requestPermission)
    {
        if (!OperatingSystem.IsAndroid())
        {
            _showNotificationPermissionHint = false;
            return;
        }

        try
        {
            PermissionStatus status;
            if (requestPermission)
            {
                status = await Permissions.RequestAsync<Permissions.PostNotifications>();
            }
            else
            {
                status = await Permissions.CheckStatusAsync<Permissions.PostNotifications>();
            }

            _showNotificationPermissionHint = status != PermissionStatus.Granted;
        }
        catch
        {
            _showNotificationPermissionHint = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        PlayerService.OnChange -= OnStateChanged;
        PlayerService.OnTimeChanged -= OnTimeChanged;
    }
}
