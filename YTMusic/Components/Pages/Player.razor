@page "/player"
@inject NavigationManager NavigationManager
@inject YTMusic.Services.MusicPlayerService PlayerService

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        NavigationManager.NavigateTo(PlayerService.IsCurrentStreamVideo ? "/player/video" : "/player/audio", replace: true);
    }
}
