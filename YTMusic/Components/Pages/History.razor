@page "/history"
@using YTMusic.ViewModels
@inject HistoryVM ViewModel
@inject NavigationManager NavigationManager
@implements IDisposable

<PageListScroll PageKey="history" ScrollId="history-page-scroll">
    <Header>
        <div class="d-flex align-center justify-space-between mb-2">
            <MudText Typo="Typo.h6">历史播放列表</MudText>
            <MudButton Variant="Variant.Text"
                       Color="Color.Default"
                       Disabled="@(ViewModel.History.Count == 0)"
                       OnClick="ClearHistoryAsync">
                清空
            </MudButton>
        </div>
    </Header>
    <ChildContent>
        @if (ViewModel.History.Count == 0)
        {
            <MudAlert Severity="Severity.Info">还没有播放记录。</MudAlert>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                @foreach (var item in ViewModel.History)
                {
                    <MudPaper Elevation="2"
                              Class="pa-3 d-flex align-center justify-space-between"
                              Style="cursor: pointer;"
                              @onclick="@(() => PlayHistoryItemAsync(item))">
                        <div class="d-flex align-center gap-3" style="min-width: 0;">
                            @if (!string.IsNullOrWhiteSpace(item.ThumbnailUrl))
                            {
                                <MudImage Src="@item.ThumbnailUrl" Width="56" Height="56" ObjectFit="ObjectFit.Cover" Class="rounded" />
                            }
                            else
                            {
                                <MudIcon Icon="@(item.IsVideo ? Icons.Material.Filled.OndemandVideo : Icons.Material.Filled.MusicNote)"
                                         Color="Color.Primary"
                                         Size="Size.Large" />
                            }
                            <div style="min-width: 0;">
                                <MediaTitle Text="@item.Title" Typo="Typo.subtitle2" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    @item.Author
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @(item.IsVideo ? "Video" : "Audio") · @item.PlayedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                                </MudText>
                            </div>
                        </div>

                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Default" />
                    </MudPaper>
                }
            </div>
        }
    </ChildContent>
</PageListScroll>

@code {
    protected override async Task OnInitializedAsync()
    {
        ViewModel.StateHasChanged = StateHasChanged;
        await ViewModel.LoadAsync();
    }

    private async Task PlayHistoryItemAsync(YTMusic.BLL.Models.PlaybackHistoryRecord item)
    {
        if (await ViewModel.PlayItemAsync(item))
        {
            NavigationManager.NavigateTo("/player");
        }
    }

    private async Task ClearHistoryAsync()
    {
        await ViewModel.ClearAsync();
    }

    public void Dispose()
    {
    }
}
