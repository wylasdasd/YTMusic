@page "/upload"
@using YTMusic.Services
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4 mb-8">
    <MudExpansionPanels Class="mb-4">
        <MudExpansionPanel Expanded="@ViewModel.IsSettingsExpanded">
            <TitleContent>
                <div class="d-flex align-center justify-space-between flex-grow-1 pr-2">
                    <div>
                        <MudText Typo="Typo.h6">Upload Settings</MudText>

                    </div>
                    <MudChip T="string" Color="@(ViewModel.IsConfigured ? Color.Success : Color.Warning)">
                        @(ViewModel.IsConfigured ? "Configured" : "Need Settings")
                    </MudChip>
                </div>
            </TitleContent>
            <ChildContent>
                <MudTextField @bind-Value="ViewModel.BaseUrl"
                              Label="AList Server URL"
                              Placeholder="https://alist.example.com"
                              Variant="Variant.Outlined"
                              Immediate="true"
                              FullWidth="true"
                              Class="mb-3" />

                <MudTextField @bind-Value="ViewModel.Token"
                              Label="AList Token"
                              Placeholder="Paste authorization token"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              Immediate="true"
                              FullWidth="true"
                              Class="mb-3" />

                <MudTextField @bind-Value="ViewModel.RemoteDirectory"
                              Label="Remote Directory"
                              Placeholder="/music/uploads"
                              Variant="Variant.Outlined"
                              Immediate="true"
                              FullWidth="true"
                              Class="mb-4" />

                <div class="d-flex flex-wrap gap-3 align-center">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ViewModel.SaveSettingsAsync">
                        Save Settings
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="ViewModel.PickAndUploadFilesAsync">
                        Choose Files
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ViewModel.CreateRemoteDirectoryAsync">
                        Create Directory
                    </MudButton>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Current target: @ViewModel.NormalizedRemoteDirectory</MudText>
                </div>
            </ChildContent>
        </MudExpansionPanel>
    </MudExpansionPanels>

    <MudTabs Elevation="1"
             Rounded="true"
             MinimumTabWidth="50%"
             @bind-ActivePanelIndex="ViewModel.SelectedTabIndex">
        <MudTabPanel Text="Local"
                     Icon="@Icons.Material.Filled.Upload"
                     BadgeData="@GetUploadLocalTabBadgeData()"
                     BadgeColor="Color.Error">
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">本地下载列表里挑选后上传</MudText>

                <div class="d-flex flex-wrap gap-3 align-center">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!ViewModel.HasSelection)" OnClick="ViewModel.UploadSelectedAsync">
                        Upload
                    </MudButton>
                    <MudToggleIconButton Toggled="@ViewModel.IsAllSelected"
                                         ToggledChanged="@ViewModel.ToggleSelectAll"
                                         Icon="@Icons.Material.Filled.SelectAll"
                                         ToggledIcon="@Icons.Material.Filled.Deselect"
                                         Variant="Variant.Text"
                                         Color="Color.Info"
                                         Title="@(ViewModel.IsAllSelected ? "Clear" : "Select All")"
                                         Disabled="@(!ViewModel.DownloadedFiles.Any())" />
                </div>
            </MudPaper>

            @if (ViewModel.IsLoading)
            {
                <div class="d-flex justify-center mt-8">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                </div>
            }
            else if (!ViewModel.DownloadedFiles.Any())
            {
                <MudAlert Severity="Severity.Info" Class="mb-4">No downloaded files found. Download music first, then upload from here.</MudAlert>
            }
            else
            {
                <div class="d-flex flex-column gap-3 mb-4">
                    @foreach (var file in ViewModel.DownloadedFiles)
                    {
                        var uploadTask = ViewModel.GetLatestUploadForFile(file.LocalFilePath);
                        <MudPaper Elevation="1" Class="pa-3">
                            <div class="d-flex align-center gap-3 flex-wrap">
                                <MudCheckBox T="bool"
                                             Value="@ViewModel.IsSelected(file.LocalFilePath)"
                                             ValueChanged="@(value => ViewModel.ToggleSelection(file.LocalFilePath, value))" />
                                @if (!string.IsNullOrWhiteSpace(file.ThumbnailUrl))
                                {
                                    <MudImage Src="@file.ThumbnailUrl" Width="56" Height="56" ObjectFit="ObjectFit.Cover" Class="rounded" />
                                }
                                else
                                {
                                    <MudIcon Icon="@(file.IsVideo ? Icons.Material.Filled.OndemandVideo : Icons.Material.Filled.MusicNote)"
                                             Size="Size.Large"
                                             Color="Color.Primary" />
                                }
                                <div class="d-flex flex-column flex-grow-1" style="overflow: hidden;">
                                    <div class="d-flex align-center gap-2 flex-wrap">
                                        <div style="min-width: 0; flex: 1 1 auto;">
                                            <MediaTitle Text="@file.Title" Typo="Typo.subtitle2" />
                                        </div>
                                        <MudChip T="string"
                                                 Size="Size.Small"
                                                 Color="@(ViewModel.ShouldShowUploadedTag(file) ? Color.Success : Color.Default)"
                                                 Variant="@(ViewModel.ShouldShowUploadedTag(file) ? Variant.Filled : Variant.Outlined)">
                                            @(ViewModel.ShouldShowUploadedTag(file) ? "Uploaded" : "Not Uploaded")
                                        </MudChip>
                                        @if (uploadTask != null)
                                        {
                                            <MudChip T="string"
                                                     Size="Size.Small"
                                                     Color="@GetStatusColor(uploadTask.Status)"
                                                     Variant="Variant.Outlined">
                                                Upload - @uploadTask.Status
                                            </MudChip>
                                        }
                                    </div>
                                   
        
                                    @if (uploadTask?.Status == DownloadStatus.Downloading)
                                    {
                                        <MudProgressLinear Color="Color.Primary" Value="@(uploadTask.Progress * 100)" Class="mt-2 mb-1" />
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@((uploadTask.Progress * 100).ToString("F1"))%</MudText>
                                    }
                                    else if (uploadTask?.Status == DownloadStatus.Failed && !string.IsNullOrWhiteSpace(uploadTask.ErrorMessage))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Error" Style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                            @uploadTask.ErrorMessage
                                        </MudText>
                                    }
                        
                                </div>
                            </div>
                        </MudPaper>
                    }
                </div>
            }
        </MudTabPanel>

        <MudTabPanel Text="Remote"
                     Icon="@Icons.Material.Filled.Cloud"
                     BadgeData="@GetRemoteTabBadgeData()"
                     BadgeColor="Color.Info">
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">浏览 Remote Directory，多选后批量下载</MudText>

                <div class="d-flex flex-wrap gap-3 align-center">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="@(!ViewModel.IsConfigured || !ViewModel.HasRemoteSelection)"
                               OnClick="ViewModel.DownloadSelectedRemoteAsync">
                        Download
                    </MudButton>
                    <MudToggleIconButton Toggled="@ViewModel.IsAllRemoteSelected"
                                         ToggledChanged="@ViewModel.ToggleRemoteSelectAll"
                                         Icon="@Icons.Material.Filled.SelectAll"
                                         ToggledIcon="@Icons.Material.Filled.Deselect"
                                         Variant="Variant.Text"
                                         Color="Color.Info"
                                         Title="@(ViewModel.IsAllRemoteSelected ? "Clear" : "Select All")"
                                         Disabled="@(!ViewModel.RemoteFiles.Any())" />
                    @* <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               Disabled="@(!ViewModel.IsConfigured)"
                               OnClick="ViewModel.RefreshRemoteFilesAsync">
                        Refresh
                    </MudButton> *@
                </div>
            </MudPaper>

            @if (!ViewModel.IsConfigured)
            {
                <MudAlert Severity="Severity.Warning" Class="mb-4">Save AList settings first, then this page can query the configured directory.</MudAlert>
            }
            else if (ViewModel.IsRemoteLoading)
            {
                <div class="d-flex justify-center mt-8">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                </div>
            }
            else if (!ViewModel.RemoteFiles.Any())
            {
                <MudAlert Severity="Severity.Info" Class="mb-4">No files found in the configured AList directory.</MudAlert>
            }
            else
            {
                <div class="d-flex flex-column gap-3 mb-4">
                    @foreach (var file in ViewModel.RemoteFiles)
                    {
                        var downloadTask = ViewModel.GetLatestRemoteDownloadForPath(file.Item.Path);
                        <MudPaper Elevation="1" Class="pa-3">
                            <div class="d-flex align-center gap-3 flex-wrap">
                                <MudCheckBox T="bool"
                                             Value="@ViewModel.IsRemoteSelected(file.Item.Path)"
                                             ValueChanged="@(value => ViewModel.ToggleRemoteSelection(file.Item.Path, value))" />
                                @if (!string.IsNullOrWhiteSpace(file.ThumbnailUrl))
                                {
                                    <MudImage Src="@file.ThumbnailUrl" Width="56" Height="56" ObjectFit="ObjectFit.Cover" Class="rounded" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.MusicNote" Size="Size.Large" Color="Color.Primary" />
                                }
                                <div class="d-flex flex-column flex-grow-1" style="overflow: hidden; min-width: 0;">
                                    <div class="d-flex align-center gap-2 flex-wrap">
                                        <div style="min-width: 0; flex: 1 1 auto;">
                                            <MediaTitle Text="@file.DisplayName" Typo="Typo.subtitle2" />
                                        </div>
                                        <MudChip T="string"
                                                 Size="Size.Small"
                                                 Color="@(ViewModel.ShouldShowDownloadedTag(file.Item.Path) ? Color.Success : Color.Default)"
                                                 Variant="@(ViewModel.ShouldShowDownloadedTag(file.Item.Path) ? Variant.Filled : Variant.Outlined)">
                                            @(ViewModel.ShouldShowDownloadedTag(file.Item.Path) ? "Downloaded" : "Not Downloaded")
                                        </MudChip>
                                        @if (downloadTask != null)
                                        {
                                            <MudChip T="string"
                                                     Size="Size.Small"
                                                     Color="@GetStatusColor(downloadTask.Status)"
                                                     Variant="Variant.Outlined">
                                                Download - @downloadTask.Status
                                            </MudChip>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(file.Subtitle))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@file.Subtitle</MudText>
                                    }
                                    @if (downloadTask?.Status == DownloadStatus.Downloading)
                                    {
                                        <MudProgressLinear Color="Color.Primary" Value="@(downloadTask.Progress * 100)" Class="mt-2 mb-1" />
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@((downloadTask.Progress * 100).ToString("F1"))%</MudText>
                                    }
                                    else if (downloadTask?.Status == DownloadStatus.Failed && !string.IsNullOrWhiteSpace(downloadTask.ErrorMessage))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Error" Style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                            @downloadTask.ErrorMessage
                                        </MudText>
                                    }
                                </div>
                            </div>
                        </MudPaper>
                    }
                </div>
            }
        </MudTabPanel>

    </MudTabs>
</MudContainer>

@code {
    [Inject] private UploadVM ViewModel { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        ViewModel.StateHasChanged = () => InvokeAsync(StateHasChanged);
        await ViewModel.LoadAsync();
    }

    public void Dispose()
    {
        ViewModel.Dispose();
    }

    private string? GetUploadLocalTabBadgeData()
        => ViewModel.HasSelection ? $"{ViewModel.SelectedFilePaths.Count}" : null;

    private string? GetRemoteTabBadgeData()
        => ViewModel.HasRemoteSelection ? $"{ViewModel.SelectedRemotePaths.Count}" : null;

    private static Color GetStatusColor(DownloadStatus status) => status switch
    {
        DownloadStatus.Pending => Color.Default,
        DownloadStatus.Downloading => Color.Info,
        DownloadStatus.Completed => Color.Success,
        DownloadStatus.Failed => Color.Error,
        _ => Color.Default
    };

    private static string FormatSize(long size)
    {
        if (size <= 0)
        {
            return "Unknown size";
        }

        string[] units = ["B", "KB", "MB", "GB"];
        double value = size;
        var unitIndex = 0;
        while (value >= 1024 && unitIndex < units.Length - 1)
        {
            value /= 1024;
            unitIndex++;
        }

        return $"{value:F1} {units[unitIndex]}";
    }
}
