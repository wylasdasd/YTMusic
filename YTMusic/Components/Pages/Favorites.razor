@page "/favorites"
@using YTMusic.Services
@implements IDisposable

<PageListScroll PageKey="favorites" ScrollId="favorites-page-scroll">
    <Header>
        @if (ViewModel.IsFolderListView)
        {
            <MudText Typo="Typo.h6" Class="favorites-page-title">收藏夹</MudText>
        }
        else
        {
            <div class="favorites-track-toolbar">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                               Color="Color.Default"
                               OnClick="BackToFolderListAsync"
                               aria-label="返回收藏夹列表" />
                <MudText Typo="Typo.h6" Class="favorites-track-toolbar__title">
                    @(ViewModel.GetSelectedFolderName() ?? "收藏夹")
                </MudText>
            </div>
            <div class="favorites-sort-field">
                <MudSelect T="FavoriteTrackSortMode"
                           Value="ViewModel.SortMode"
                           ValueChanged="ViewModel.SetSortModeAsync"
                           Label="排序方式"
                           Variant="Variant.Outlined"
                           FullWidth="true"
                           Dense="true">
                    <MudSelectItem T="FavoriteTrackSortMode" Value="FavoriteTrackSortMode.Time">时间</MudSelectItem>
                    <MudSelectItem T="FavoriteTrackSortMode" Value="FavoriteTrackSortMode.Name">名称</MudSelectItem>
                    @if (!ViewModel.IsDownloadedCatalogSelected)
                    {
                        <MudSelectItem T="FavoriteTrackSortMode" Value="FavoriteTrackSortMode.Downloaded">已下载</MudSelectItem>
                        <MudSelectItem T="FavoriteTrackSortMode" Value="FavoriteTrackSortMode.NotDownloaded">未下载</MudSelectItem>
                    }
                </MudSelect>
            </div>
            @if (ViewModel.IsDownloadedCatalogSelected)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                    已下载目录同步自本地下载列表，无法手动添加或取消收藏。
                </MudAlert>
            }
        }
    </Header>
    <ChildContent>
        @if (ViewModel.IsFolderListView)
        {
            @if (ViewModel.Folders.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Class="mt-4">暂无收藏夹。</MudAlert>
            }
            else
            {
                <div class="favorites-folder-list">
                    @foreach (var folder in ViewModel.Folders)
                    {
                        var trackCount = ViewModel.FolderTrackCounts.GetValueOrDefault(folder.Id);
                        var coverUrl = ViewModel.FolderCoverUrls.GetValueOrDefault(folder.Id);
                        var firstAuthor = ViewModel.FolderFirstTrackAuthors.GetValueOrDefault(folder.Id);
                        <MudPaper Elevation="2"
                                  Class="favorites-folder-row pa-3 d-flex align-center"
                                  @onclick="() => OpenFolderAsync(folder.Id)">
                            @if (!string.IsNullOrWhiteSpace(coverUrl))
                            {
                                <MudImage Src="@coverUrl"
                                         Width="60"
                                         Height="60"
                                         ObjectFit="ObjectFit.Cover"
                                         Class="favorites-folder-row__thumb rounded mr-3" />
                            }
                            else
                            {
                                <div class="favorites-folder-row__thumb favorites-folder-row__thumb--empty mr-3">
                                    <MudIcon Icon="@Icons.Material.Filled.Album" Color="Color.Primary" />
                                </div>
                            }

                            <div class="favorites-folder-row__meta flex-grow-1">
                                <MediaTitle Text="@folder.Name" Typo="Typo.subtitle1" Class="favorites-folder-row__title" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="favorites-folder-row__subtitle">
                             
                                    
                                        @(trackCount > 0 ? $"{trackCount} 首" : "暂无歌曲")
                                    
                                </MudText>
                            </div>

                            <div @onclick:stopPropagation="true">
                                <MudIconButton Icon="@Icons.Material.Filled.Shuffle"
                                               Color="Color.Error"
                                               Disabled="@(trackCount == 0)"
                                               OnClick="@(() => PlayFolderAsync(folder.Id, MusicPlayerService.PlaybackMode.Random))"
                                               aria-label="随机播放" />
                            </div>
                            <div @onclick:stopPropagation="true">
                                <MudIconButton Icon="@Icons.Material.Filled.PlayArrow"
                                               Color="Color.Primary"
                                               Disabled="@(trackCount == 0)"
                                               OnClick="@(() => PlayFolderAsync(folder.Id, MusicPlayerService.PlaybackMode.Sequential))"
                                               aria-label="顺序播放" />
                            </div>
                            @if (!FavoriteFolderIds.IsProtectedFolder(folder.Id))
                            {
                                <div @onclick:stopPropagation="true">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Color="Color.Error"
                                                   OnClick="@(() => ViewModel.ConfirmDeleteFolderAsync(folder))"
                                                   aria-label="删除收藏夹" />
                                </div>
                            }
                        </MudPaper>
                    }
                </div>
            }
        }
        else if (ViewModel.IsLoading)
        {
            <div class="d-flex justify-center mt-8">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            </div>
        }
        else if (!ViewModel.Tracks.Any())
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">
                @(ViewModel.IsDownloadedCatalogSelected ? "暂无本地下载文件。" : "当前收藏夹没有符合条件的歌曲。")
            </MudAlert>
        }
        else
        {
            <MudGrid Class="mt-2 justify-center">
                @foreach (var track in ViewModel.Tracks)
                {
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <MudCard Elevation="2" Style="height: 100%; display: flex; flex-direction: column; cursor: pointer;"
                                 @onclick="@(() => PlayTrack(track))">
                            @if (UiPreferences.ShowFavoriteCardImages)
                            {
                                <MudCardMedia Image="@track.ThumbnailUrl" Height="160" />
                            }
                            <MudCardContent Style="flex-grow: 1;">
                                <MediaTitle Text="@track.Title" Typo="Typo.subtitle1" />
                            </MudCardContent>
                            <MudCardActions Class="favorites-card__footer">
                                @if (track.IsDownloaded)
                                {
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Color="Color.Success"
                                             Variant="Variant.Outlined"
                                             Icon="@Icons.Material.Filled.CheckCircle">
                                        Downloaded
                                    </MudChip>
                                }
                                <MudSpacer />
                                @if (track.HasDownloadedVideo)
                                {
                                    <div @onclick:stopPropagation="true">
                                        <MudIconButton Icon="@Icons.Material.Filled.OndemandVideo"
                                                       Color="Color.Secondary"
                                                       OnClick="@(async (e) => await PlayLocalVideoAsync(track))"
                                                       aria-label="Play local video" />
                                    </div>
                                }
                                @if (!ViewModel.IsDownloadedCatalogSelected)
                                {
                                    <div @onclick:stopPropagation="true">
                                        <MudIconButton Icon="@Icons.Material.Filled.Favorite" Color="Color.Primary"
                                                       OnClick="@(async (e) => { await ViewModel.ConfirmRemoveFavoriteAsync(track); })"
                                                       aria-label="Remove from favorites" />
                                    </div>
                                }
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    </ChildContent>
</PageListScroll>

@code {
    [Inject] private FavoritesVM ViewModel { get; set; } = default!;
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
    [Inject] private MusicPlayerService PlayerService { get; set; } = default!;
    [Inject] private GlobalStateService GlobalState { get; set; } = default!;
    [Inject] private UiPreferencesService UiPreferences { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        ViewModel.StateHasChanged = StateHasChanged;
        UiPreferences.OnChange += OnUiPreferencesChanged;
        await ViewModel.InitializeAsync();
    }

    private Task OpenFolderAsync(int folderId) => ViewModel.OpenFolderAsync(folderId);

    private Task BackToFolderListAsync()
    {
        ViewModel.BackToFolderList();
        return Task.CompletedTask;
    }

    private async Task PlayTrack(FavoriteTrack track)
    {
        try
        {
            GlobalState.ShowLoading();
            StateHasChanged();

            if (ViewModel.Tracks.Any())
            {
                var playlist = BuildPlaylist(ViewModel.Tracks);
                int startIndex = ViewModel.Tracks.FindIndex(t =>
                    t.VideoId == track.VideoId &&
                    string.Equals(t.LocalFilePath, track.LocalFilePath, StringComparison.OrdinalIgnoreCase));
                if (startIndex == -1) startIndex = 0;

                string folderName = ViewModel.GetSelectedFolderName() ?? "收藏夹";

                if (await PlayerService.PlayPlaylistAsync(playlist, startIndex, folderName, MusicPlayerService.PlaybackMode.Sequential))
                {
                    NavigationManager.NavigateTo("/player");
                }
            }
        }
        finally
        {
            GlobalState.HideLoading();
            StateHasChanged();
        }
    }

    private async Task PlayFolderAsync(int folderId, MusicPlayerService.PlaybackMode mode)
    {
        try
        {
            GlobalState.ShowLoading();
            StateHasChanged();

            var tracks = await ViewModel.LoadTracksForFolderAsync(folderId);
            if (!tracks.Any())
            {
                return;
            }

            var folderName = ViewModel.Folders.FirstOrDefault(f => f.Id == folderId)?.Name ?? "收藏夹";
            var playlist = BuildPlaylist(tracks, FavoriteFolderIds.IsDownloadedCatalog(folderId));

            if (await PlayerService.PlayPlaylistAsync(playlist, 0, folderName, mode))
            {
                NavigationManager.NavigateTo("/player");
            }
        }
        finally
        {
            GlobalState.HideLoading();
            StateHasChanged();
        }
    }

    private List<PlayingItem> BuildPlaylist(IEnumerable<FavoriteTrack> tracks, bool? forceDownloadedCatalog = null)
    {
        var isDownloadedCatalog = forceDownloadedCatalog ?? ViewModel.IsDownloadedCatalogSelected;
        return tracks.Select(t => new PlayingItem
        {
            VideoId = t.VideoId,
            Title = t.Title,
            Author = t.Author,
            ThumbnailUrl = t.ThumbnailUrl,
            LocalFilePath = t.IsDownloaded || isDownloadedCatalog ? t.LocalFilePath : null,
            IsVideo = false
        }).ToList();
    }

    private async Task PlayLocalVideoAsync(FavoriteTrack track)
    {
        if (!track.HasDownloadedVideo || string.IsNullOrWhiteSpace(track.LocalVideoFilePath))
        {
            return;
        }

        try
        {
            GlobalState.ShowLoading();
            StateHasChanged();

            if (await PlayerService.PlayLocalFileAsync(
                track.LocalVideoFilePath,
                track.Title,
                true,
                track.Author,
                track.ThumbnailUrl))
            {
                NavigationManager.NavigateTo("/player");
            }
        }
        finally
        {
            GlobalState.HideLoading();
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        ViewModel.StateHasChanged = null;
        UiPreferences.OnChange -= OnUiPreferencesChanged;
    }

    private void OnUiPreferencesChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }
}
