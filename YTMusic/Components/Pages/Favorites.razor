@page "/favorites"
@using YTMusic.Services
@using MudBlazor
@implements IDisposable

<PageListScroll PageKey="favorites" ScrollId="favorites-page-scroll">
    <Header>
        <MudText Typo="Typo.h6" Class="favorites-page-title">收藏夹</MudText>
    </Header>
    <ChildContent>
        @if (ViewModel.Folders.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">暂无收藏夹。</MudAlert>
        }
        else
        {
            <div class="favorites-folder-list">
                @foreach (var folder in ViewModel.Folders)
                {
                    var trackCount = ViewModel.FolderTrackCounts.GetValueOrDefault(folder.Id);
                    var coverUrl = ViewModel.FolderCoverUrls.GetValueOrDefault(folder.Id);
                    <MudPaper Elevation="2"
                              Class="favorites-folder-row pa-3 d-flex align-center"
                              @onclick="() => ViewModel.NavigateToFolder(folder.Id)">
                        @if (!string.IsNullOrWhiteSpace(coverUrl))
                        {
                            <MudImage Src="@coverUrl"
                                     Width="60"
                                     Height="60"
                                     ObjectFit="ObjectFit.Cover"
                                     Class="favorites-folder-row__thumb rounded mr-3" />
                        }
                        else
                        {
                            <div class="favorites-folder-row__thumb favorites-folder-row__thumb--empty mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.Album" Color="Color.Primary" />
                            </div>
                        }

                        <div class="favorites-folder-row__meta flex-grow-1">
                            <MediaTitle Text="@folder.Name" Typo="Typo.subtitle1" Class="favorites-folder-row__title" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="favorites-folder-row__subtitle">
                                @(trackCount > 0 ? $"{trackCount} 首" : "暂无歌曲")
                            </MudText>
                        </div>

                        <div @onclick:stopPropagation="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Shuffle"
                                           Color="Color.Error"
                                           Disabled="@(trackCount == 0)"
                                           OnClick="@(() => ViewModel.PlayFolderAsync(folder.Id, MusicPlayerService.PlaybackMode.Random))"
                                           aria-label="随机播放" />
                        </div>
                        <div @onclick:stopPropagation="true">
                            <MudIconButton Icon="@Icons.Material.Filled.PlayArrow"
                                           Color="Color.Primary"
                                           Disabled="@(trackCount == 0)"
                                           OnClick="@(() => ViewModel.PlayFolderAsync(folder.Id, MusicPlayerService.PlaybackMode.Sequential))"
                                           aria-label="顺序播放" />
                        </div>
                        @if (FavoriteFolderIds.IsDownloadedCatalog(folder.Id))
                        {
                            <div @onclick:stopPropagation="true">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               Disabled="@(trackCount == 0)"
                                               OnClick="@(() => ViewModel.ConfirmClearLocalDownloadsAsync())"
                                               aria-label="删除本地文件" />
                            </div>
                        }
                        else if (!FavoriteFolderIds.IsProtectedFolder(folder.Id))
                        {
                            <div @onclick:stopPropagation="true">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               OnClick="@(() => ViewModel.ConfirmDeleteFolderAsync(folder))"
                                               aria-label="删除收藏夹" />
                            </div>
                        }
                    </MudPaper>
                }
            </div>
        }
    </ChildContent>
</PageListScroll>

<div class="favorites-fab-wrap">
    <MudFab StartIcon="@Icons.Material.Filled.Add"
            Color="Color.Primary"
            aria-label="新建收藏夹"
            OnClick="@(async () => await ViewModel.OpenCreateFolderDialogCommand.ExecuteAsync(null))" />
</div>

@code {
    [Inject] private FavoritesVM ViewModel { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        ViewModel.StateHasChanged = StateHasChanged;
        await ViewModel.InitializeAsync();
    }

    public void Dispose()
    {
        ViewModel.StateHasChanged = null;
    }
}
