@page "/favorites"
@using YTMusic.Services
@implements IDisposable

<PageListScroll PageKey="favorites" ScrollId="favorites-page-scroll">
    <Header>
<div class="favorites-toolbar">
    <div class="favorites-toolbar__field">
        <MudSelect T="int" Value="ViewModel.SelectedFolderId" ValueChanged="ViewModel.SetFolderAsync" Label="Folder"
                   Variant="Variant.Outlined" FullWidth="true" Dense="true">
            @foreach (var folder in ViewModel.Folders)
            {
                <MudSelectItem T="int" Value="@folder.Id">@folder.Name</MudSelectItem>
            }
        </MudSelect>
    </div>

    @if (!ViewModel.IsDownloadedCatalogSelected)
    {
        <div class="favorites-toolbar__field">
            <MudSelect T="int" Value="ViewModel.DownloadFilter" ValueChanged="ViewModel.SetFilterAsync" Label="Filter"
                       Variant="Variant.Outlined" FullWidth="true" Dense="true">
                <MudSelectItem T="int" Value="0">All Tracks</MudSelectItem>
                <MudSelectItem T="int" Value="1">Downloaded</MudSelectItem>
                <MudSelectItem T="int" Value="2">Not Downloaded</MudSelectItem>
            </MudSelect>
        </div>
    }
</div>

@if (ViewModel.IsDownloadedCatalogSelected)
{
    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
        已下载目录同步自本地下载列表，无法手动添加或取消收藏。
    </MudAlert>
}

<div class="favorites-actions">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PlayArrow"
               OnClick="PlayAllAsync" Disabled="@(!ViewModel.Tracks.Any())">
        播放全部
    </MudButton>
    <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Shuffle"
               OnClick="ShuffleAllAsync" Disabled="@(!ViewModel.Tracks.Any())">
        随机播放
    </MudButton>
</div>
    </Header>
    <ChildContent>
@if (ViewModel.IsLoading)
{
    <div class="d-flex justify-center mt-8">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
    </div>
}
else if (!ViewModel.Tracks.Any())
{
    <MudAlert Severity="Severity.Info" Class="mt-4">
        @(ViewModel.IsDownloadedCatalogSelected ? "暂无本地下载文件。" : "No favorites found in this folder with the current filter.")
    </MudAlert>
}
else
{
    <MudGrid Class="mt-4 justify-center">
        @foreach (var track in ViewModel.Tracks)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard Elevation="2" Style="height: 100%; display: flex; flex-direction: column; cursor: pointer;"
                         @onclick="@(() => PlayTrack(track))">
                    @if (UiPreferences.ShowFavoriteCardImages)
                    {
                        <MudCardMedia Image="@track.ThumbnailUrl" Height="160" />
                    }
                    <MudCardContent Style="flex-grow: 1;">
                        <MediaTitle Text="@track.Title" Typo="Typo.subtitle1" />
                    </MudCardContent>
                    <MudCardActions Class="favorites-card__footer">
                        @if (track.IsDownloaded)
                        {
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Color="Color.Success"
                                     Variant="Variant.Outlined"
                                     Icon="@Icons.Material.Filled.CheckCircle">
                                Downloaded
                            </MudChip>
                        }
                        <MudSpacer />
                        @if (track.HasDownloadedVideo)
                        {
                            <div @onclick:stopPropagation="true">
                                <MudIconButton Icon="@Icons.Material.Filled.OndemandVideo"
                                               Color="Color.Secondary"
                                               OnClick="@(async (e) => await PlayLocalVideoAsync(track))"
                                               aria-label="Play local video" />
                            </div>
                        }
                        @if (!ViewModel.IsDownloadedCatalogSelected)
                        {
                            <div @onclick:stopPropagation="true">
                                <MudIconButton Icon="@Icons.Material.Filled.Favorite" Color="Color.Primary"
                                               OnClick="@(async (e) => { await ViewModel.ConfirmRemoveFavoriteAsync(track); })"
                                               aria-label="Remove from favorites" />
                            </div>
                        }
                    </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
    </ChildContent>
</PageListScroll>

@code {
    [Inject] private FavoritesVM ViewModel { get; set; } = default!;
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
    [Inject] private MusicPlayerService PlayerService { get; set; } = default!;
    [Inject] private YTMusic.Services.GlobalStateService GlobalState { get; set; } = default!;
    [Inject] private UiPreferencesService UiPreferences { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        ViewModel.StateHasChanged = StateHasChanged;
        UiPreferences.OnChange += OnUiPreferencesChanged;
        await ViewModel.InitializeAsync();
    }

    private async Task PlayTrack(FavoriteTrack track)
    {
        try
        {
            GlobalState.ShowLoading();
            StateHasChanged();

            if (ViewModel.Tracks.Any())
            {
                var playlist = ViewModel.Tracks.Select(t => new PlayingItem
                {
                    VideoId = t.VideoId,
                    Title = t.Title,
                    Author = t.Author,
                    ThumbnailUrl = t.ThumbnailUrl,
                    LocalFilePath = t.IsDownloaded || ViewModel.IsDownloadedCatalogSelected ? t.LocalFilePath : null,
                    IsVideo = false
                }).ToList();

                int startIndex = ViewModel.Tracks.FindIndex(t =>
                    t.VideoId == track.VideoId &&
                    string.Equals(t.LocalFilePath, track.LocalFilePath, StringComparison.OrdinalIgnoreCase));
                if (startIndex == -1) startIndex = 0;

                string folderName = ViewModel.Folders.FirstOrDefault(f => f.Id == ViewModel.SelectedFolderId)?.Name ?? "收藏夹";

                if (await PlayerService.PlayPlaylistAsync(playlist, startIndex, folderName, MusicPlayerService.PlaybackMode.Sequential))
                {
                    NavigationManager.NavigateTo("/player");
                }
            }
        }
        finally
        {
            GlobalState.HideLoading();
            StateHasChanged();
        }
    }

    private async Task PlayAllAsync()
    {
        if (!ViewModel.Tracks.Any()) return;
        await PlayWithModeAsync(MusicPlayerService.PlaybackMode.Sequential);
    }

    private async Task ShuffleAllAsync()
    {
        if (!ViewModel.Tracks.Any()) return;
        await PlayWithModeAsync(MusicPlayerService.PlaybackMode.Random);
    }

    private async Task PlayWithModeAsync(MusicPlayerService.PlaybackMode mode)
    {
        try
        {
            GlobalState.ShowLoading();
            StateHasChanged();

            var playlist = ViewModel.Tracks.Select(t => new PlayingItem
            {
                VideoId = t.VideoId,
                Title = t.Title,
                Author = t.Author,
                ThumbnailUrl = t.ThumbnailUrl,
                LocalFilePath = t.IsDownloaded || ViewModel.IsDownloadedCatalogSelected ? t.LocalFilePath : null,
                IsVideo = false
            }).ToList();

            string folderName = ViewModel.Folders.FirstOrDefault(f => f.Id == ViewModel.SelectedFolderId)?.Name ?? "收藏夹";

            if (await PlayerService.PlayPlaylistAsync(playlist, 0, folderName, mode))
            {
                NavigationManager.NavigateTo("/player");
            }
        }
        finally
        {
            GlobalState.HideLoading();
            StateHasChanged();
        }
    }

    private async Task PlayLocalVideoAsync(FavoriteTrack track)
    {
        if (!track.HasDownloadedVideo || string.IsNullOrWhiteSpace(track.LocalVideoFilePath))
        {
            return;
        }

        try
        {
            GlobalState.ShowLoading();
            StateHasChanged();

            if (await PlayerService.PlayLocalFileAsync(
                track.LocalVideoFilePath,
                track.Title,
                true,
                track.Author,
                track.ThumbnailUrl))
            {
                NavigationManager.NavigateTo("/player");
            }
        }
        finally
        {
            GlobalState.HideLoading();
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        ViewModel.StateHasChanged = null;
        UiPreferences.OnChange -= OnUiPreferencesChanged;
    }

    private void OnUiPreferencesChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }
}
