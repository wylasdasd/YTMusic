@page "/transfers"
@using System.Linq
@using YTMusic.Services
@implements IDisposable

<div class="d-flex align-center gap-2 mt-4 mb-4" style="overflow-x: auto;">
    <MudChip T="string"
             Color="@(ViewModel.CurrentFilter == TransfersVM.TransferFilter.All ? Color.Primary : Color.Default)"
             Variant="@(ViewModel.CurrentFilter == TransfersVM.TransferFilter.All ? Variant.Filled : Variant.Outlined)"
             OnClick="@(() => ViewModel.SetFilter(TransfersVM.TransferFilter.All))">
        All
    </MudChip>
    <MudChip T="string"
             Color="@(ViewModel.CurrentFilter == TransfersVM.TransferFilter.Active ? Color.Primary : Color.Default)"
             Variant="@(ViewModel.CurrentFilter == TransfersVM.TransferFilter.Active ? Variant.Filled : Variant.Outlined)"
             OnClick="@(() => ViewModel.SetFilter(TransfersVM.TransferFilter.Active))">
        Active
    </MudChip>
    <MudChip T="string"
             Color="@(ViewModel.CurrentFilter == TransfersVM.TransferFilter.Completed ? Color.Success : Color.Default)"
             Variant="@(ViewModel.CurrentFilter == TransfersVM.TransferFilter.Completed ? Variant.Filled : Variant.Outlined)"
             OnClick="@(() => ViewModel.SetFilter(TransfersVM.TransferFilter.Completed))">
        Completed
    </MudChip>
    <MudChip T="string"
             Color="@(ViewModel.CurrentFilter == TransfersVM.TransferFilter.Failed ? Color.Error : Color.Default)"
             Variant="@(ViewModel.CurrentFilter == TransfersVM.TransferFilter.Failed ? Variant.Filled : Variant.Outlined)"
             OnClick="@(() => ViewModel.SetFilter(TransfersVM.TransferFilter.Failed))">
        Failed
    </MudChip>
</div>

@if (!ViewModel.FilteredDownloads.Any())
{
    <MudAlert Severity="Severity.Info" Class="mt-4">@GetEmptyMessage()</MudAlert>
}
else
{
    <div class="d-flex flex-column gap-4 mt-4">
        @foreach (var task in ViewModel.FilteredDownloads.Reverse())
        {
            <MudPaper Elevation="2" Class="pa-4">
                <div class="d-flex justify-space-between align-center mb-2">
                    <MudText Typo="Typo.subtitle1" Style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 70%;">
                        @task.Title
                    </MudText>
                    <MudChip Size="Size.Small" Color="GetStatusColor(task.Status)" T="string">
                        @(task.IsVideo ? "Video" : "Audio") - @task.Status.ToString()
                    </MudChip>
                </div>
                
                @if (task.Status == DownloadStatus.Downloading)
                {
                    <MudProgressLinear Color="Color.Primary" Value="@(task.Progress * 100)" Class="my-2" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@((task.Progress * 100).ToString("F1"))%</MudText>
                }
                else if (task.Status == DownloadStatus.Failed)
                {
                    <MudText Typo="Typo.caption" Color="Color.Error">@task.ErrorMessage</MudText>
                }
            </MudPaper>
        }
    </div>
}

@code {
    [Inject] private TransfersVM ViewModel { get; set; } = default!;

    protected override void OnInitialized()
    {
        ViewModel.StateHasChanged = () => InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ViewModel.Dispose();
    }

    private Color GetStatusColor(DownloadStatus status) => status switch
    {
        DownloadStatus.Pending => Color.Default,
        DownloadStatus.Downloading => Color.Info,
        DownloadStatus.Completed => Color.Success,
        DownloadStatus.Failed => Color.Error,
        _ => Color.Default
    };

    private string GetEmptyMessage() => ViewModel.CurrentFilter switch
    {
        TransfersVM.TransferFilter.Active => "No active downloads.",
        TransfersVM.TransferFilter.Completed => "No completed downloads yet.",
        TransfersVM.TransferFilter.Failed => "No failed downloads.",
        _ => "No transfers yet."
    };
}
