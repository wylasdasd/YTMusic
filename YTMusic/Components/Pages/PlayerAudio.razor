@page "/player/audio"
@using YTMusic.BLL.Ports
@using YTMusic.Services
@using MudBlazor
@inject MusicPlayerService PlayerService
@inject PlayerVM ViewModel
@inject IUiNotifier Notifier
@inject NavigationManager NavigationManager
@inject GlobalStateService GlobalState
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageListScroll PageKey="player-audio" Class="player-page-scroll">
    <ChildContent>
<MudContainer MaxWidth="MaxWidth.False" Class="player-screen player-screen--audio">
    @if (PlayerService.CurrentVideo != null)
    {
        <div class="player-shell">
            <div class="player-backdrop"
                 style="@($"background-image: linear-gradient(180deg, color-mix(in srgb, var(--ytm-bg-base) 18%, transparent), color-mix(in srgb, var(--ytm-bg-base) 92%, transparent)), url('{PlayerService.CurrentVideo.ThumbnailUrl}');")">
            </div>

            <div class="player-content">
                <div class="player-artwork-wrap">
                    <div class="player-artwork-shadow"></div>
                    <MudImage Src="@PlayerService.CurrentVideo.ThumbnailUrl"
                              ObjectFit="ObjectFit.Cover"
                              Class="player-artwork" />
                </div>

                <div class="player-meta">
                    @if (!string.IsNullOrEmpty(PlayerService.CurrentPlaylistName))
                    {
                        <MudText Typo="Typo.caption" Class="player-kicker">
                            正在播放: @PlayerService.CurrentPlaylistName
                        </MudText>
                    }
                    <MediaTitle Text="@PlayerService.CurrentVideo.Title"
                                Typo="Typo.h5"
                                Class="player-title" />
                    <MudText Typo="Typo.body1" Class="player-author">
                        @PlayerService.CurrentVideo.Author
                    </MudText>
                </div>

                <div class="player-progress" @ref="_progressHost"></div>

                <div class="player-actions-row">
                    <div class="player-actions-left">
                        @if (PlayerService.IsCurrentStreamVideo)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.MusicNote"
                                           Color="Color.Secondary"
                                           OnClick="PlayAudioAsync"
                                           Disabled="@PlayerService.IsSwitchingTrack"
                                           aria-label="Switch to audio" />
                        }
                        else if (PlayerService.CanShowVideoToggle())
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.OndemandVideo"
                                           Color="Color.Secondary"
                                           OnClick="PlayVideoAsync"
                                           Disabled="@PlayerService.IsSwitchingTrack"
                                           aria-label="Play video" />
                        }
                        <MudIconButton
                            Icon="@(ViewModel.IsFavorite ? Icons.Material.Filled.Favorite : Icons.Material.Outlined.FavoriteBorder)"
                            Color="@(ViewModel.IsFavorite ? Color.Error : Color.Default)"
                            OnClick="OpenFavoriteDialogAsync"
                            aria-label="Toggle Favorite" />
                        <MudMenu Icon="@Icons.Material.Filled.Download"
                                 Color="Color.Primary"
                                 AnchorOrigin="Origin.BottomRight"
                                 TransformOrigin="Origin.TopRight"
                                 aria-label="Download">
                            <MudMenuItem OnClick="@(() => Download(false))">Download Audio</MudMenuItem>
                            <MudMenuItem OnClick="@(() => Download(true))">Download Video</MudMenuItem>
                        </MudMenu>
                    </div>

                    <MudIconButton Icon="@PlayerVM.GetPlaybackModeIcon(PlayerService.CurrentMode)"
                                   Color="Color.Default"
                                   Size="Size.Medium"
                                   OnClick="TogglePlaybackMode"
                                   aria-label="Toggle Playback Mode"
                                   Disabled="@(PlayerService.Playlist.Count == 0)" />
                </div>

                <div class="player-controls">
                    <MudIconButton Icon="@Icons.Material.Filled.SkipPrevious"
                                   Size="Size.Large"
                                   Variant="Variant.Text"
                                   OnClick="PlayPreviousTrack"
                                   Disabled="@(PlayerService.Playlist.Count == 0 || PlayerService.IsSwitchingTrack)" />

                    @if (PlayerService.IsLoading)
                    {
                        <MudProgressCircular Size="Size.Large" Indeterminate="true" Class="mx-2" />
                    }
                    else
                    {
                        <MudIconButton Icon="@(PlayerService.IsPlaying ? Icons.Material.Filled.PauseCircle : Icons.Material.Filled.PlayCircle)"
                                       Size="Size.Large"
                                       Color="Color.Primary"
                                       OnClick="TogglePlay"
                                       Disabled="@PlayerService.IsSwitchingTrack"
                                       Class="player-main-button" />
                    }

                    <MudIconButton Icon="@Icons.Material.Filled.SkipNext"
                                   Size="Size.Large"
                                   Variant="Variant.Text"
                                   OnClick="PlayNextTrack"
                                   Disabled="@(PlayerService.Playlist.Count == 0 || PlayerService.IsSwitchingTrack)" />
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="player-empty">
            <MudIcon Icon="@Icons.Material.Filled.MusicOff" Style="font-size: 4rem;" Color="Color.Secondary" Class="mb-4" />
            <MudText Typo="Typo.h5" Color="Color.Secondary">No track is currently playing</MudText>
        </div>
    }
</MudContainer>
    </ChildContent>
</PageListScroll>

@code {
    private ElementReference _progressHost;
    private bool _progressMounted;
    private string? _progressTrackKey;
    private bool _lastNativeProgressMode;

    protected override void OnInitialized()
    {
        ViewModel.StateHasChanged = StateHasChanged;
        PlayerService.OnChange += OnStateChanged;
        _ = ViewModel.RefreshFavoriteStatusAsync(PlayerService.CurrentVideo);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (PlayerService.CurrentVideo != null)
        {
            await MountProgressBarAsync();
        }
    }

    private void OnStateChanged()
    {
        if (PlayerService.IsCurrentStreamVideo)
        {
            if (!(OperatingSystem.IsAndroid() && PlayerService.UseNativeVideoPlayback))
            {
                NavigationManager.NavigateTo("/player/video", replace: true);
            }
            return;
        }

        _ = ViewModel.RefreshFavoriteStatusAsync(PlayerService.CurrentVideo);
        _ = SyncPlayerChromeAsync();
        InvokeAsync(StateHasChanged);
    }

    private string? GetProgressTrackKey()
    {
        var current = PlayerService.CurrentVideo;
        if (current == null)
        {
            return null;
        }

        return !string.IsNullOrEmpty(current.LocalFilePath) ? current.LocalFilePath : current.VideoId;
    }

    private async Task SyncPlayerChromeAsync()
    {
        var trackKey = GetProgressTrackKey();
        var native = PlayerService.IsUsingNativePlayback || PlayerService.IsUsingNativeVideoPlayback;
        if (!_progressMounted || trackKey != _progressTrackKey)
        {
            _progressTrackKey = trackKey;
            await MountProgressBarAsync();
        }
        else if (native != _lastNativeProgressMode)
        {
            await SyncProgressModeAsync();
        }
        else if (PlayerService.IsSwitchingTrack)
        {
            await JSRuntime.InvokeVoidAsync(
                "audioPlayer.setProgress",
                PlayerService.CurrentTime,
                PlayerService.Duration,
                true);
        }

        _lastNativeProgressMode = native;
    }

    private async Task MountProgressBarAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("audioPlayer.mountProgressBar", _progressHost);
            await SyncProgressModeAsync();
            await JSRuntime.InvokeVoidAsync(
                "audioPlayer.setProgress",
                PlayerService.CurrentTime,
                PlayerService.Duration,
                true);
            _progressMounted = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PlayerAudio] mount progress failed: {ex.Message}");
        }
    }

    private async Task SyncProgressModeAsync()
    {
        var native = PlayerService.IsUsingNativePlayback || PlayerService.IsUsingNativeVideoPlayback;
        await JSRuntime.InvokeVoidAsync("audioPlayer.setNativeProgressMode", native);
    }

    private async Task OpenFavoriteDialogAsync()
    {
        var currentVideo = PlayerService.CurrentVideo;
        if (currentVideo == null)
        {
            return;
        }

        await ViewModel.OpenFavoriteDialogAsync(currentVideo);
    }

    private async Task TogglePlay()
    {
        if (PlayerService.IsPlaying)
            await PlayerService.PauseAsync();
        else
            await PlayerService.ResumeAsync();
    }

    private async Task PlayVideoAsync()
    {
        if (!PlayerService.CanShowVideoToggle() || PlayerService.IsSwitchingTrack)
        {
            return;
        }

        var currentVideo = PlayerService.CurrentVideo;
        if (currentVideo == null)
        {
            return;
        }

        if (await PlayerService.CanPlayLocalVideoForCurrentAsync())
        {
            await NavigateToVideoIfSwitchedAsync(await PlayerService.PlayCurrentAsVideoAsync());
            return;
        }

        if (string.IsNullOrWhiteSpace(currentVideo.VideoId) || currentVideo.VideoId == "local")
        {
            Notifier.Warning("当前曲目没有可用的视频 ID，无法在线播放视频。");
            return;
        }

        if (!await ViewModel.ConfirmRemoteVideoPlayAsync(currentVideo.Title))
        {
            return;
        }

        try
        {
            GlobalState.ShowLoading();
            StateHasChanged();

            var playOk = await PlayerService.PlayRemoteVideoForCurrentAsync();
            PlaybackDiagnostics.Log(
                $"PlayerAudio.PlayVideo playOk={playOk} isVideo={PlayerService.IsCurrentStreamVideo} hybrid={PlayerService.IsUsingHybridWebVideo} url={PlaybackDiagnostics.DescribeUrl(PlayerService.CurrentStreamUrl)}");
            if (!await NavigateToVideoIfSwitchedAsync(playOk))
            {
                PlaybackDiagnostics.LogError(
                    $"PlayerAudio.PlayVideo navigate failed playOk={playOk} isVideo={PlayerService.IsCurrentStreamVideo}");
                Notifier.Error("在线视频播放失败，视频可能不可用或网络异常。");
            }
        }
        finally
        {
            GlobalState.HideLoading();
            StateHasChanged();
        }
    }

    private Task<bool> NavigateToVideoIfSwitchedAsync(bool switched)
    {
        if (!switched)
        {
            PlaybackDiagnostics.Log("NavigateToVideo skipped: play returned false");
            return Task.FromResult(false);
        }

        if (!PlayerService.IsCurrentStreamVideo)
        {
            PlaybackDiagnostics.Log(
                $"NavigateToVideo skipped: IsCurrentStreamVideo=false hybrid={PlayerService.IsUsingHybridWebVideo}");
            return Task.FromResult(false);
        }

        if (!(OperatingSystem.IsAndroid() && PlayerService.UseNativeVideoPlayback))
        {
            PlaybackDiagnostics.Log("NavigateToVideo -> /player/video");
            NavigationManager.NavigateTo("/player/video");
        }

        return Task.FromResult(true);
    }

    private async Task PlayAudioAsync()
    {
        if (PlayerService.IsSwitchingTrack)
        {
            return;
        }

        if (await PlayerService.PlayCurrentAsAudioAsync())
        {
            NavigationManager.NavigateTo("/player/audio", replace: true);
        }
        else
        {
            Notifier.Warning("无法切换到音频播放。");
        }
    }

    private async Task PlayNextTrack()
    {
        await PlayerService.PlayNextAsync();
    }

    private async Task PlayPreviousTrack()
    {
        await PlayerService.PlayPreviousAsync();
    }

    private void TogglePlaybackMode()
    {
        PlayerService.TogglePlaybackMode();
        StateHasChanged();
    }

    private void Download(bool isVideo)
    {
        var currentVideo = PlayerService.CurrentVideo;
        if (currentVideo == null)
        {
            return;
        }

        ViewModel.Download(currentVideo, isVideo);
    }

    public void Dispose()
    {
        PlayerService.OnChange -= OnStateChanged;
        if (_progressMounted)
        {
            _ = JSRuntime.InvokeVoidAsync("audioPlayer.unmountProgressBar");
        }
    }
}
