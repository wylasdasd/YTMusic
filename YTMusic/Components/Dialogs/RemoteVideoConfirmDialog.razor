@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body1">
            本地仅保存了音频文件，无法直接播放视频。
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
            「@TrackTitle」可从远端获取原视频流并在线播放（不下载到本地）。
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Color="Color.Default">取消</MudButton>
        <MudButton OnClick="Confirm" Color="Color.Primary" Variant="Variant.Filled">在线播放视频</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string TrackTitle { get; set; } = string.Empty;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void Confirm()
    {
        MudDialog.Close(DialogResult.Ok(true));
    }
}
