@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="FolderName"
                      Label="收藏夹名称"
                      Variant="Variant.Outlined"
                      Immediate="true"
                      FullWidth="true"
                      MaxLength="64"
                      Counter="64"
                      Placeholder="例如：工作、通勤" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Color="Color.Default">取消</MudButton>
        <MudButton OnClick="Confirm" Color="Color.Primary" Variant="Variant.Filled" Disabled="@string.IsNullOrWhiteSpace(FolderName)">
            创建
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private string FolderName { get; set; } = string.Empty;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void Confirm()
    {
        MudDialog.Close(DialogResult.Ok(FolderName.Trim()));
    }
}
