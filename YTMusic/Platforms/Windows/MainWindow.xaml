        <local:MainPage />
    </Window.Page>
    <Window.TitleBar>
        <TitleBar x:Name="titleBar"
                  BackgroundColor="#5E35B1"
                  ForegroundColor="#5E35B1"
                  HeightRequest="0">
        </TitleBar>
    </Window.TitleBar>
</Window>
